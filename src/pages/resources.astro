---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import CustomCursor from '../components/CustomCursor.astro';

const socials = [
  { platform: "YouTube", handle: "@the.lucas.project", url: "https://youtube.com/@the.lucas.project.1", anim: "bounce" },
  { platform: "Instagram", handle: "@the.lucas.project", url: "https://www.instagram.com/the.lucas.project", anim: "spin" },
  { platform: "TikTok", handle: "@lucas.project", url: "https://www.tiktok.com/@lucas.project", anim: "wiggle" },
  { platform: "LinkedIn", handle: "Lucas Weeden", url: "https://www.linkedin.com/in/lucas-weeden-6721133bb", anim: "slide" },
  { platform: "Facebook", handle: "The Lucas Project", url: "https://www.facebook.com/share/18Th9LsXYL/", anim: "pulse" },
  { platform: "Threads", handle: "@the.lucas.project", url: "https://www.threads.com/@the.lucas.project", anim: "rock" },
  { platform: "Snapchat", handle: "lucas.weeden", url: "https://snapchat.com/t/66goy6LY", anim: "flip" },
  { platform: "Instagram", handle: "@lucas.weeden", url: "https://www.instagram.com/lucas.weeden", anim: "glow" },
];
---

<Layout title="Resources — Lucas Weeden">
  <ScrollProgress />
  <Nav />
  <CustomCursor />

  <main style="position: relative; z-index: 2; padding-top: 120px; min-height: 80vh;">
    <section class="site-section" id="resources">
      <div class="section-inner" style="text-align: center;">
        <div class="section-label">09 — Resources</div>
        <h2 class="section-title">RESOURCES</h2>

        <div style="display: inline-flex; align-items: center; gap: 12px; margin-bottom: 40px; padding: 12px 20px; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg);">
          <span id="resource-url" style="font-family: 'Syne', sans-serif; font-size: 14px; letter-spacing: 0.05em; color: var(--text); user-select: all;">lucasweeden.com/resources</span>
          <button id="copy-link-btn" style="font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 8px 16px; border: 1px solid var(--accent); background: transparent; color: var(--accent); border-radius: 4px; transition: all 0.3s ease;">Copy Link</button>
        </div>

        <p style="font-size: 20px; opacity: 0.8; max-width: 500px; margin: 0 auto 20px;">
          Collabs, podcasts, brand deals, or just say what's up.
        </p>
        <a href="mailto:Lucasproject@lucasweeden.com" class="contact-email-btn">
          Lucasproject@lucasweeden.com
        </a>
      </div>
    </section>

    <!-- Follow The Journey — moved from main page -->
    <section class="site-section" id="social">
      <div class="section-inner">
        <div class="section-label">Stay Connected</div>
        <h2 class="section-title">FOLLOW THE JOURNEY</h2>
        <div class="social-grid">
          {socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" class="social-card" data-anim={s.anim}>
              <div class="social-icon">
                <img src="/images/smallLucas_Project_Logo.png" alt="LP" />
              </div>
              <div class="social-platform">{s.platform}</div>
              <div class="social-handle">{s.handle}</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.getElementById('copy-link-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('https://lucasweeden.com/resources').then(() => {
      const btn = document.getElementById('copy-link-btn');
      if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy Link'; }, 2000); }
    });
  });

  // Activate social card animations when scrolled into view
  const socialGrid = document.querySelector('.social-grid');
  if (socialGrid) {
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        socialGrid.querySelectorAll('.social-card').forEach((card, i) => {
          setTimeout(() => card.classList.add('anim-active'), i * 100);
        });
      }
    }, { threshold: 0.3 });
    observer.observe(socialGrid);
  }
</script>
