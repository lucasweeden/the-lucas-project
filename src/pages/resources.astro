---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import CustomCursor from '../components/CustomCursor.astro';

const socials = [
  { platform: "YouTube", url: "https://youtube.com/@the.lucas.project.1", anim: "bounce" },
  { platform: "Instagram", url: "https://www.instagram.com/the.lucas.project", anim: "spin" },
  { platform: "TikTok", url: "https://www.tiktok.com/@lucas.project", anim: "wiggle" },
  { platform: "LinkedIn", url: "https://www.linkedin.com/in/lucas-weeden-6721133bb", anim: "slide" },
  { platform: "Facebook", url: "https://www.facebook.com/share/18Th9LsXYL/", anim: "pulse" },
  { platform: "Threads", url: "https://www.threads.com/@the.lucas.project", anim: "rock" },
  { platform: "Snapchat", url: "https://snapchat.com/t/66goy6LY", anim: "flip" },
  { platform: "Instagram (Personal)", url: "https://www.instagram.com/lucas.weeden", anim: "glow" },
];
---

<Layout title="Resources — Lucas Weeden">
  <ScrollProgress />
  <Nav />
  <CustomCursor />

  <!-- LP coins background (same as homepage) -->
  <div id="lp-coin-bg" style="position: absolute; top: 0; left: 0; width: 100%; z-index: 0; pointer-events: none; overflow: hidden;"></div>

  <main style="position: relative; z-index: 2; min-height: 100vh;">
    <!-- Follow The Journey -->
    <section class="site-section" id="social" style="min-height:100vh;display:flex;align-items:center;">
      <div class="section-inner">
        <div class="section-label" style="text-align:center;">Stay Connected</div>
        <h2 class="section-title" style="text-align:center;">FOLLOW THE JOURNEY</h2>
        <div class="social-grid-big">
          {socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" class="social-card-big" data-anim={s.anim}>
              <div class="social-icon-big"><img src="/images/smallLucas_Project_Logo.png" alt="LP" /></div>
              <div class="social-platform-big">{s.platform}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Resources -->
    <section class="site-section" id="resources">
      <div class="section-inner" style="text-align: center;">
        <div class="section-label">09 — Resources</div>
        <h2 class="section-title">RESOURCES</h2>

        <div style="display: inline-flex; align-items: center; gap: 12px; margin-bottom: 40px; padding: 12px 20px; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg);">
          <span style="font-family:'Syne',sans-serif;font-size:14px;letter-spacing:0.05em;color:var(--text);user-select:all;">lucasweeden.com/resources</span>
          <button id="copy-link-btn" style="font-family:'Syne',sans-serif;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;padding:8px 16px;border:1px solid var(--accent);background:transparent;color:var(--accent);border-radius:4px;transition:all 0.3s ease;">Copy Link</button>
        </div>

        <!-- Clickable resource cards (Change 5) -->
        <div class="res-cards-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:800px;margin:0 auto 48px;text-align:left;">
          <div class="card res-card" data-subject="Collab Inquiry" style="padding:24px;transition:border-color 0.2s ease,transform 0.2s ease;">
            <div class="card-title" style="font-size:20px;">Collabs</div>
            <div class="card-body">Open to brand collaborations and partnerships.</div>
            <div style="font-family:'Syne',sans-serif;font-size:11px;color:rgba(140,216,103,0.5);margin-top:12px;">Click to reach out →</div>
          </div>
          <div class="card res-card" data-subject="Podcast Booking" style="padding:24px;transition:border-color 0.2s ease,transform 0.2s ease;">
            <div class="card-title" style="font-size:20px;">Podcasts</div>
            <div class="card-body">Book Lucas for podcast appearances.</div>
            <div style="font-family:'Syne',sans-serif;font-size:11px;color:rgba(140,216,103,0.5);margin-top:12px;">Click to reach out →</div>
          </div>
          <div class="card res-card" data-subject="Brand Deal Inquiry" style="padding:24px;transition:border-color 0.2s ease,transform 0.2s ease;">
            <div class="card-title" style="font-size:20px;">Brand Deals</div>
            <div class="card-body">Reach out about sponsorships and brand deals.</div>
            <div style="font-family:'Syne',sans-serif;font-size:11px;color:rgba(140,216,103,0.5);margin-top:12px;">Click to reach out →</div>
          </div>
        </div>

        <button id="email-form-toggle" class="contact-email-btn" type="button">
          Lucasproject@lucasweeden.com
        </button>
      </div>
    </section>

    <div id="scroll-trap" style="height:300vh;position:relative;">
      <div id="back-home-hint" style="position:sticky;top:50%;text-align:center;font-family:'Syne',sans-serif;font-size:18px;color:var(--accent);opacity:0;transition:opacity 0.5s ease;letter-spacing:0.1em;">← Back to Home</div>
    </div>
  </main>

  <!-- Email form modal -->
  <div id="email-modal" style="position:fixed;bottom:0;left:0;width:100%;max-height:85vh;background:#060d04;border-top:2px solid #3a7a2a;border-radius:20px 20px 0 0;padding:40px;z-index:10000;transform:translateY(100%);transition:transform 300ms ease;backdrop-filter:blur(20px);overflow-y:auto;">
    <button id="email-modal-close" style="position:absolute;top:16px;right:20px;background:none;border:none;color:#5aba32;font-size:24px;">✕</button>
    <h3 style="font-family:'Bebas Neue',sans-serif;font-size:32px;color:#8cd867;margin-bottom:24px;text-align:center;letter-spacing:2px;">GET IN TOUCH</h3>
    <form id="contact-form" action="https://formspree.io/f/xpwdjkeo" method="POST" style="max-width:500px;margin:0 auto;display:flex;flex-direction:column;gap:14px;">
      <input type="text" name="name" placeholder="Your Name" required class="form-field" />
      <input type="email" name="email" placeholder="Your Email" required class="form-field" />
      <input type="text" name="subject" id="form-subject-res" placeholder="Subject" class="form-field" />
      <textarea name="message" placeholder="Your message..." required class="form-field" style="min-height:140px;resize:vertical;"></textarea>
      <button type="submit" style="width:100%;background:#3a7a2a;color:#e8f5e0;font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:2px;border:none;border-radius:8px;padding:14px;transition:background 200ms ease;">SEND MESSAGE</button>
    </form>
    <div id="form-success" style="display:none;text-align:center;color:#8cd867;font-family:'Syne',sans-serif;font-size:18px;margin-top:24px;">Message sent. I'll be in touch.</div>
  </div>

  <Footer />
</Layout>

<style>
  .form-field { background:rgba(26,77,10,0.3);border:1px solid #3a7a2a;border-radius:8px;color:#e8f5e0;padding:12px 16px;font-family:'Syne',sans-serif;font-size:14px;width:100%;box-sizing:border-box; }
  .form-field:focus { border-color:#5aba32;outline:none;box-shadow:0 0 0 2px rgba(90,186,50,0.2); }
  .res-card:hover { border-color:#5aba32 !important; transform:scale(1.02); }
  .social-grid-big { display:grid;grid-template-columns:repeat(4,1fr);gap:20px; }
  .social-card-big { background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:32px 24px;text-align:center;text-decoration:none;color:var(--text);display:flex;flex-direction:column;align-items:center;gap:16px;min-height:160px;justify-content:center;transition:transform 0.3s ease,box-shadow 0.3s ease,border-color 0.3s ease; }
  .social-card-big:hover { transform:translateY(-4px);box-shadow:0 12px 40px var(--shadow);border-color:var(--accent);color:var(--text); }
  .social-icon-big img { width:56px;height:56px;border-radius:50%; }
  .social-platform-big { font-family:'Syne',sans-serif;font-size:18px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em; }
  .social-card-big[data-anim="bounce"] { animation:socBounce 1.2s ease-in-out infinite; }
  .social-card-big[data-anim="spin"] { animation:socSpin 4s linear infinite; }
  .social-card-big[data-anim="wiggle"] { animation:socWiggle 0.4s ease-in-out infinite; }
  .social-card-big[data-anim="slide"] { animation:socSlide 2s ease-in-out infinite; }
  .social-card-big[data-anim="pulse"] { animation:socPulse 1.5s ease-in-out infinite; }
  .social-card-big[data-anim="rock"] { animation:socRock 2s ease-in-out infinite; }
  .social-card-big[data-anim="flip"] { animation:socFlip 1.8s ease-in-out infinite; }
  .social-card-big[data-anim="glow"] { animation:socGlow 2s ease-in-out infinite; }
  .social-card-big { animation-play-state:paused; }
  .social-card-big.anim-active { animation-play-state:running; }
  @media (max-width:768px) {
    .social-grid-big { grid-template-columns:repeat(2,1fr); }
    .res-cards-grid { grid-template-columns: 1fr !important; }
  }
  @media (max-width:480px) { .social-grid-big { grid-template-columns:1fr; } }
</style>

<script>
  import { initFloatingCoins, initStardust } from '../scripts/particles';
  document.addEventListener('DOMContentLoaded', () => { initFloatingCoins(); initStardust(); });
</script>

<script>
  // Copy link
  document.getElementById('copy-link-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText('https://lucasweeden.com/resources').then(() => {
      const btn = document.getElementById('copy-link-btn');
      if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy Link'; }, 2000); }
    });
  });

  // Social card animations
  document.querySelectorAll('.social-card-big').forEach((card, i) => {
    setTimeout(() => card.classList.add('anim-active'), i * 100 + 500);
  });

  // Email form
  const emailModal = document.getElementById('email-modal');
  const subjectField = document.getElementById('form-subject-res') as HTMLInputElement;

  function openForm(subject?: string) {
    if (emailModal) emailModal.style.transform = 'translateY(0)';
    if (subject && subjectField) subjectField.value = subject;
  }

  document.getElementById('email-form-toggle')?.addEventListener('click', () => openForm());
  document.getElementById('email-modal-close')?.addEventListener('click', () => {
    if (emailModal) emailModal.style.transform = 'translateY(100%)';
  });

  // Resource cards → open form with pre-filled subject
  document.querySelectorAll('.res-card').forEach(card => {
    card.addEventListener('click', () => {
      openForm((card as HTMLElement).dataset.subject || '');
    });
  });

  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    try { await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'Accept': 'application/json' } }); } catch {}
    form.style.display = 'none';
    const s = document.getElementById('form-success');
    if (s) s.style.display = 'block';
  });

  // Scroll-to-home trap
  const trap = document.getElementById('scroll-trap');
  const hint = document.getElementById('back-home-hint');
  let scrollTicks = 0, trapActive = false;
  if (trap) {
    const obs = new IntersectionObserver(([e]) => { trapActive = e.isIntersecting; if (!trapActive) scrollTicks = 0; }, { threshold: 0.05 });
    obs.observe(trap);
  }
  window.addEventListener('scroll', () => {
    if (hint && trap) {
      const r = trap.getBoundingClientRect();
      hint.style.opacity = r.top < window.innerHeight ? String(Math.min((window.innerHeight - r.top) / (r.height * 0.3), 0.8)) : '0';
    }
  });
  window.addEventListener('wheel', (e) => { if (trapActive && e.deltaY > 0) { scrollTicks++; if (scrollTicks >= 3) window.location.href = '/'; } });
</script>
