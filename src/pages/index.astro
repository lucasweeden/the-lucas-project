---
import Layout from '../layouts/Layout.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Nav from '../components/Nav.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Hero from '../components/Hero.astro';
import LucasProject from '../components/LucasProject.astro';
import Gallery from '../components/Gallery.astro';
import Building from '../components/Building.astro';
import About from '../components/About.astro';
import Wins from '../components/Wins.astro';
import Ventures from '../components/Ventures.astro';
import Limitless from '../components/Limitless.astro';
import Social from '../components/Social.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <LoadingScreen />
  <ScrollProgress />
  <Nav />
  <CustomCursor />

  <!-- Global particle canvas (Change 14) -->
  <canvas id="global-particles"></canvas>

  <!-- Floating LP coins (Change 14) -->
  {Array.from({ length: 18 }).map((_, i) => (
    <img
      src="/images/smallLucas_Project_Logo.png"
      alt=""
      class="floating-lp-coin"
      style={`
        top: ${5 + Math.floor((i * 37) % 90)}vh;
        left: ${3 + Math.floor((i * 53) % 92)}vw;
        animation-delay: ${(i * 0.4).toFixed(1)}s;
        animation-duration: ${6 + (i % 3)}s;
        opacity: ${(0.25 + (i % 4) * 0.1).toFixed(2)};
        width: ${40 + (i % 4) * 5}px;
        height: ${40 + (i % 4) * 5}px;
      `}
    />
  ))}

  <main>
    <Hero />
    <LucasProject />
    <Gallery />
    <Building />
    <About />
    <Wins />
    <Ventures />
    <Limitless />
    <Social />
    <Contact />
  </main>

  <Footer />
</Layout>

<script>
  import { initGlobalParticles } from '../scripts/particles';
  import { initAnimations } from '../scripts/animations';

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize global particle canvas (Change 14)
    const globalCanvas = document.getElementById('global-particles') as HTMLCanvasElement;
    if (globalCanvas) {
      initGlobalParticles(globalCanvas);
    }

    // Initialize GSAP animations
    initAnimations();
  });
</script>
