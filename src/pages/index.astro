---
import Layout from '../layouts/Layout.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Nav from '../components/Nav.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Hero from '../components/Hero.astro';
import LucasProject from '../components/LucasProject.astro';
import Gallery from '../components/Gallery.astro';
import Building from '../components/Building.astro';
import About from '../components/About.astro';
import Wins from '../components/Wins.astro';
import Ventures from '../components/Ventures.astro';
import Limitless from '../components/Limitless.astro';
import Social from '../components/Social.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <LoadingScreen />
  <ScrollProgress />
  <Nav />
  <CustomCursor />

  <!-- Change 10: LP coins background (z-index: 0) -->
  <div id="lp-coin-bg" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: hidden;"></div>

  <main style="position: relative; z-index: 2;">
    <Hero />
    <LucasProject />
    <Gallery />
    <Building />
    <About />
    <Wins />
    <Ventures />
    <Limitless />
    <Social />
    <Contact />
  </main>

  <Footer />
</Layout>

<script>
  import { initFloatingCoins, initCursorSparks } from '../scripts/particles';
  import { initAnimations } from '../scripts/animations';

  document.addEventListener('DOMContentLoaded', () => {
    initFloatingCoins();
    initCursorSparks();
    initAnimations();
  });
</script>
