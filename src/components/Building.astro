---
// Change 4: Equal size cards + scratch-to-reveal cover
---
<section class="site-section" id="building">
  <div class="section-inner">
    <div class="section-label">03 — Right Now</div>
    <h2 class="section-title">WHAT I'M BUILDING</h2>
    <div id="building-reveal-wrapper" style="position:relative;">
      <canvas id="scratch-canvas" style="position:absolute;top:0;left:0;width:100%;height:100%;z-index:10;border-radius:16px;"></canvas>
      <div class="equal-cards">
        <div class="card tilt-card eq-card">
          <img src="/images/Limitless_Roofing_Solutions_-_4.png" alt="Limitless Roofing Solutions" class="card-logo" style="width:56px;height:56px;" loading="lazy" />
          <div class="card-title" style="font-size:20px;">Limitless Roofing Solutions</div>
          <div class="card-body">Co-founding an AI-powered automation CRM with my partner Chase. Custom-built workflows for every roofing company's exact job flow, plus our Lead Secure System — when someone calls and nobody picks up, the caller instantly gets a custom text with links to schedule, fill out forms, leave reviews, or chat with an AI bot.</div>
          <span class="card-badge green">Active — Launching</span>
        </div>
        <div class="card tilt-card eq-card">
          <img src="/images/smallLucas_Project_Logo.png" alt="The Lucas Project" class="card-logo" style="width:56px;height:56px;" />
          <div class="card-title" style="font-size:20px;">The Lucas Project</div>
          <div class="card-body">Documenting the build in public across YouTube, Instagram, TikTok — the hub all roads lead back to.</div>
          <span class="card-badge teal">Always On</span>
        </div>
        <div class="card tilt-card eq-card">
          <img src="/images/ai-learning-communities-logo.png" alt="AI Learning Communities" class="card-logo" style="width:56px;height:auto;border-radius:4px;" loading="lazy" />
          <div class="card-title" style="font-size:20px;">AI Learning Communities</div>
          <div class="card-body">Building a community and education platform to help real people learn and apply AI to their businesses and lives. Not theory — practical, applied, and built from the ground up alongside Limitless.</div>
          <span class="card-badge green">Active — Launching</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .equal-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .eq-card { min-height: 400px; padding: 28px; }
  @media (max-width: 1024px) {
    .equal-cards { grid-template-columns: 1fr; }
    .eq-card { min-height: auto; }
  }
</style>

<script>
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { gsap } from 'gsap';
  gsap.registerPlugin(ScrollTrigger);

  const wrapper = document.getElementById('building-reveal-wrapper');
  const scratchCanvas = document.getElementById('scratch-canvas') as HTMLCanvasElement;

  if (wrapper && scratchCanvas) {
    let covered = false;
    let revealed = false;

    function setupScratch() {
      if (revealed) return;
      const rect = wrapper.getBoundingClientRect();
      const w = rect.width;
      const h = rect.height;
      scratchCanvas.width = w;
      scratchCanvas.height = h;
      scratchCanvas.style.width = w + 'px';
      scratchCanvas.style.height = h + 'px';

      const ctx = scratchCanvas.getContext('2d');
      if (!ctx) return;

      // Fill dark cover
      ctx.fillStyle = '#0a1a05';
      ctx.fillRect(0, 0, w, h);

      // Diagonal texture lines
      ctx.strokeStyle = 'rgba(58,122,42,0.12)';
      ctx.lineWidth = 1;
      for (let i = -h; i < w + h; i += 20) {
        ctx.beginPath();
        ctx.moveTo(i, 0);
        ctx.lineTo(i - h, h);
        ctx.stroke();
      }

      // Border
      ctx.strokeStyle = '#3a7a2a';
      ctx.lineWidth = 2;
      ctx.strokeRect(1, 1, w - 2, h - 2);

      // Text
      ctx.fillStyle = '#5aba32';
      ctx.font = "bold 48px 'Bebas Neue', Impact, sans-serif";
      ctx.textAlign = 'center';
      ctx.fillText('DRAG TO REVEAL', w / 2, h * 0.4);

      ctx.fillStyle = 'rgba(140,216,103,0.7)';
      ctx.font = "16px 'Syne', sans-serif";
      ctx.fillText('← move your cursor across to uncover →', w / 2, h * 0.55);

      covered = true;

      // Scratch on hover (no click required)
      function erase(e: MouseEvent | TouchEvent) {
        if (revealed) return;
        const cr = scratchCanvas.getBoundingClientRect();
        let x: number, y: number;
        if ('touches' in e) {
          x = e.touches[0].clientX - cr.left;
          y = e.touches[0].clientY - cr.top;
        } else {
          x = e.clientX - cr.left;
          y = e.clientY - cr.top;
        }
        ctx.globalCompositeOperation = 'destination-out';
        ctx.beginPath();
        ctx.arc(x, y, 40, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-over';
      }

      scratchCanvas.addEventListener('mousemove', erase);
      scratchCanvas.addEventListener('touchmove', erase, { passive: true });

      // Check percent erased periodically
      const checkInterval = setInterval(() => {
        if (revealed) { clearInterval(checkInterval); return; }
        const imageData = ctx.getImageData(0, 0, w, h);
        let transparent = 0;
        for (let i = 3; i < imageData.data.length; i += 16) {
          if (imageData.data[i] === 0) transparent++;
        }
        const totalSampled = Math.ceil(imageData.data.length / 16);
        if (transparent / totalSampled > 0.6) {
          revealed = true;
          clearInterval(checkInterval);
          gsap.to(scratchCanvas, { opacity: 0, duration: 0.6, onComplete: () => { scratchCanvas.remove(); } });
        }
      }, 300);
    }

    // Setup when section scrolls into view; re-setup if user returns
    ScrollTrigger.create({
      trigger: wrapper,
      start: 'top 80%',
      onEnter: () => { if (!covered) setupScratch(); },
      onEnterBack: () => {
        if (revealed) {
          // Reset for re-experience
          revealed = false;
          covered = false;
          const parent = document.getElementById('building-reveal-wrapper');
          if (parent && !document.getElementById('scratch-canvas')) {
            const newCanvas = document.createElement('canvas');
            newCanvas.id = 'scratch-canvas';
            newCanvas.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;z-index:10;border-radius:16px;';
            parent.prepend(newCanvas);
          }
        }
      }
    });
  }
</script>
