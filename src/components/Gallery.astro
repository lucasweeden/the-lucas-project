---
const photos = [
  { src: "IMG_4863.jpeg", caption: "Golden Hour" },
  { src: "IMG_1530.jpeg", caption: "Powder Days" },
  { src: "IMG_6652.jpeg", caption: "On Stage" },
  { src: "IMG_3496.jpeg", caption: "Saddle Up" },
  { src: "IMG_4898.jpeg", caption: "Prom Night" },
  { src: "IMG_2047.jpeg", caption: "Texas Made" },
  { src: "IMG_9474.jpeg", caption: "Night Out" },
  { src: "IMG_0717.jpeg", caption: "Island Life" },
  { src: "IMG_1001.jpeg", caption: "Golden Fields" },
  { src: "IMG_4459.jpeg", caption: "Acoustic" },
  { src: "IMG_2720.jpeg", caption: "Road Trip" },
  { src: "IMG_4848.jpeg", caption: "Pack Walk" },
  { src: "IMG_0856.jpeg", caption: "Camp Life" },
  { src: "IMG_1218.PNG", caption: "Game Day", isGameDay: true },
  { src: "IMG_2829.jpeg", caption: "Great Grandpa Harold" },
  { src: "IMG_0045.jpeg", caption: "Dog Run" },
  { src: "IMG_5426.jpeg", caption: "Sand Dunes" },
  { src: "IMG_2282.jpeg", caption: "Baby Lucas" },
  { src: "IMG_4463.jpeg", caption: "Festival" },
  { src: "IMG_1426.jpeg", caption: "Family" },
];
const count = photos.length;
const radius = 900;
---
<section class="site-section" id="gallery">
  <div class="section-inner" style="margin-bottom: 64px;">
    <div class="section-label">02 — The Life</div>
    <h2 class="section-title">LIVING WIDE OPEN</h2>
    <p class="section-subtitle">No filter. No highlight reel. Just the climb.</p>
  </div>
  <div class="carousel-scene" id="carousel-scene" style="padding-top: 48px;">
    <div class="carousel-container" id="photoCarousel">
      {photos.map((photo, i) => {
        const angle = (360 / count) * i;
        return (
          <div class={`carousel-card ${photo.isGameDay ? 'game-day-card' : ''}`}
            data-index={i} data-src={`/images/${photo.src}`} data-caption={photo.caption}
            style={`transform: rotateY(${angle}deg) translateZ(${radius}px);`}>
            <img src={`/images/${photo.src}`} alt={photo.caption} loading="lazy" onerror="this.parentElement.style.display='none'" />
            <div class="card-title">{photo.caption}</div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<div class="lightbox" id="lightbox">
  <button class="lightbox-close" id="lightbox-close">&times;</button>
  <img id="lightbox-img" src="" alt="" />
  <div class="lightbox-caption" id="lightbox-caption"></div>
</div>

<style>
  .carousel-scene {
    width: 100%; height: 600px;
    perspective: 2200px; perspective-origin: 50% 40%;
    display: flex; align-items: center; justify-content: center;
    overflow: visible; position: relative;
  }
  .carousel-container {
    width: 220px; height: 340px;
    position: relative; transform-style: preserve-3d;
    transform: rotateX(8deg) rotateY(0deg);
  }
  .carousel-card {
    position: absolute; width: 220px; height: 340px;
    border-radius: 12px; overflow: hidden;
    backface-visibility: visible;
    border: 2px solid rgba(90,186,50,0.4);
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
    transition: opacity 0.15s ease, filter 0.15s ease;
  }
  .carousel-card img {
    width: 100%; height: 80%; object-fit: cover; object-position: center top; display: block;
  }
  .game-day-card img { object-position: center 15%; }
  .card-title {
    height: 20%; display: flex; align-items: center; justify-content: center;
    background: rgba(6,13,4,0.9); color: #8cd867;
    font-family: 'Syne', sans-serif; font-size: 13px;
    letter-spacing: 1px; padding: 0 12px; text-align: center;
  }
  @media (max-width: 768px) {
    .carousel-scene { height: 400px; }
    .carousel-container { width: 160px; height: 260px; }
    .carousel-card { width: 160px; height: 260px; }
  }
</style>

<script>
  const scene = document.getElementById('carousel-scene');
  const container = document.getElementById('photoCarousel');
  const cards = document.querySelectorAll('.carousel-card');
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption');
  const lbClose = document.getElementById('lightbox-close');
  const total = cards.length;
  const R = 900;

  if (container && scene) {
    let rotation = 0, velocity = 0, isDragging = false, lastX = 0;

    function updateCardDepth() {
      cards.forEach((card, i) => {
        const cardAngle = (360 / total) * i;
        let diff = ((cardAngle + rotation) % 360 + 360) % 360;
        if (diff > 180) diff = 360 - diff;
        const t = diff / 180;
        const scale = 1.0 - t * 0.45;
        const opacity = 1.0 - t * 0.6;
        const brightness = 1.0 - t * 0.5;
        (card as HTMLElement).style.transform = `rotateY(${cardAngle}deg) translateZ(${R}px) scale(${scale})`;
        (card as HTMLElement).style.opacity = String(opacity);
        (card as HTMLElement).style.filter = `brightness(${brightness})`;
      });
    }

    scene.addEventListener('wheel', (e) => { e.preventDefault(); velocity += e.deltaY * 0.3; }, { passive: false });
    scene.addEventListener('mousedown', (e) => { isDragging = true; lastX = e.clientX; });
    window.addEventListener('mousemove', (e) => { if (!isDragging) return; velocity += (e.clientX - lastX) * 0.8; lastX = e.clientX; });
    window.addEventListener('mouseup', () => { isDragging = false; });
    scene.addEventListener('touchstart', (e) => { lastX = e.touches[0].clientX; });
    scene.addEventListener('touchmove', (e) => { velocity += (e.touches[0].clientX - lastX) * 0.8; lastX = e.touches[0].clientX; });

    function animateCarousel() {
      velocity *= 0.94;
      rotation += velocity * 0.01;
      container.style.transform = `rotateX(8deg) rotateY(${rotation}deg)`;
      updateCardDepth();
      requestAnimationFrame(animateCarousel);
    }
    animateCarousel();
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      if (lbImg) lbImg.src = card.getAttribute('data-src') || '';
      if (lbCaption) lbCaption.textContent = card.getAttribute('data-caption') || '';
      lightbox?.classList.add('active');
    });
  });
  lbClose?.addEventListener('click', () => lightbox?.classList.remove('active'));
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) lightbox.classList.remove('active'); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') lightbox?.classList.remove('active'); });
</script>
