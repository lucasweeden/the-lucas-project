---
const photos = [
  { src: "IMG_4863.jpeg", caption: "Golden Hour" },
  { src: "IMG_1530.jpeg", caption: "Powder Days" },
  { src: "IMG_6652.jpeg", caption: "On Stage" },
  { src: "IMG_3496.jpeg", caption: "Saddle Up" },
  { src: "IMG_4898.jpeg", caption: "Prom Night" },
  { src: "IMG_2047.jpeg", caption: "Texas Made" },
  { src: "IMG_9474.jpeg", caption: "Night Out" },
  { src: "IMG_0717.jpeg", caption: "Island Life" },
  { src: "IMG_1001.jpeg", caption: "Golden Fields" },
  { src: "IMG_4459.jpeg", caption: "Acoustic" },
  { src: "IMG_2720.jpeg", caption: "Road Trip" },
  { src: "IMG_4848.jpeg", caption: "Pack Walk" },
  { src: "IMG_0856.jpeg", caption: "Camp Life" },
  { src: "IMG_1218.PNG", caption: "Game Day", isGameDay: true },
  { src: "IMG_2829.jpeg", caption: "Great Grandpa" },
  { src: "IMG_0045.jpeg", caption: "Dog Run" },
  { src: "IMG_5426.jpeg", caption: "Sand Dunes" },
  { src: "IMG_2282.jpeg", caption: "Baby Lucas" },
  { src: "IMG_4463.jpeg", caption: "Festival" },
  { src: "IMG_1426.jpeg", caption: "Family" },
];
const count = photos.length;
const radius = 900;
const GAME_DAY_IDX = 13;
// Game Day needs ~4.5 deg extra arc for its wider card (400px vs 260px)
// Distribute that extra space: Game Day gets BASE + 4.5, other 19 cards each lose 4.5/19 ≈ 0.237 deg
const GD_EXTRA = 4.5;
const NORMAL_ANGLE = (360 - (360 / count + GD_EXTRA)) / (count - 1); // ~17.76 deg for normal cards
const GD_ANGLE = 360 / count + GD_EXTRA; // ~22.5 deg for Game Day

// Precompute cumulative angles for perfectly even visual spacing
function getCardAngle(idx: number): number {
  let angle = 0;
  for (let i = 0; i < idx; i++) {
    angle += (i === GAME_DAY_IDX) ? GD_ANGLE : NORMAL_ANGLE;
  }
  return angle;
}
---
<section class="site-section" id="gallery" style="display:flex;flex-direction:column;align-items:stretch;">
  <!-- EDIT 1: Text is in a separate block, above the carousel, never overlapping -->
  <div class="gallery-heading">
    <div class="section-label">02 — The Life</div>
    <h2 class="section-title">LIVING WIDE OPEN</h2>
    <p class="section-subtitle">No filter. No highlight reel. Just the climb.</p>
  </div>

  <!-- EDIT 1+2: Carousel pushed down with clear separation -->
  <div class="carousel-scene" id="carousel-scene">
    <div class="carousel-container" id="photoCarousel">
      {photos.map((photo, i) => {
        const angle = getCardAngle(i);
        return (
          <div class={`carousel-card ${photo.isGameDay ? 'game-day-card' : ''}`}
            data-index={i} data-src={`/images/${photo.src}`} data-caption={photo.caption}
            style={`transform: rotateY(${angle}deg) translateZ(${radius}px);`}>
            <img src={`/images/${photo.src}`} alt={photo.caption} loading="lazy" onerror="this.parentElement.style.display='none'" />
            <div class="card-title">{photo.caption}</div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<div class="lightbox" id="lightbox">
  <button class="lightbox-close" id="lightbox-close">&times;</button>
  <img id="lightbox-img" src="" alt="" />
  <div class="lightbox-caption" id="lightbox-caption"></div>
</div>

<style>
  .gallery-heading {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    padding-bottom: 40px;
    position: relative;
    z-index: 2;
    /* nothing below this can overlap — heading is in normal doc flow */
  }

  .carousel-scene {
    width: 100%;
    height: 580px;
    margin-top: 160px; /* increased gap so text never overlaps any card at any rotation */
    perspective: 2200px;
    perspective-origin: 50% 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
    position: relative;
  }
  .carousel-container {
    width: 260px; height: 400px;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(8deg) rotateY(0deg);
  }
  .carousel-card {
    position: absolute;
    width: 260px; height: 400px;
    border-radius: 12px; overflow: hidden;
    backface-visibility: visible;
    border: 2px solid rgba(90,186,50,0.4);
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
    transition: opacity 0.15s ease, filter 0.15s ease;
    will-change: transform, opacity;
    /* center the card on the transform origin */
    left: 50%; top: 50%;
    margin-left: -130px; margin-top: -200px;
  }
  .carousel-card img {
    width: 100%; height: 80%;
    object-fit: cover; object-position: center top;
    display: block;
  }
  .game-day-card {
    width: 400px !important; height: 260px !important;
    margin-left: -200px !important; margin-top: -130px !important;
    transform-origin: center center;
  }
  .game-day-card img {
    object-fit: contain;
    object-position: center center;
    background: #000;
  }
  .card-title {
    height: 20%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(6,13,4,0.9); color: #8cd867;
    font-family: 'Syne', sans-serif; font-size: 13px;
    letter-spacing: 1px; padding: 0 12px; text-align: center;
  }
  @media (max-width: 768px) {
    .gallery-heading { padding: 0 20px; }
    .carousel-scene { height: 400px; margin-top: 60px; }
    .carousel-container { width: 180px; height: 280px; }
    .carousel-card { width: 180px; height: 280px; margin-left: -90px; margin-top: -140px; }
    .game-day-card { width: 300px !important; height: 200px !important; margin-left: -150px !important; margin-top: -100px !important; }
  }
</style>

<script>
  const sceneEl = document.getElementById('carousel-scene');
  const container = document.getElementById('photoCarousel');
  const cards = document.querySelectorAll('.carousel-card');
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption');
  const lbClose = document.getElementById('lightbox-close');
  const total = cards.length;
  const R = 900;
  const GD_I = 13;
  const GD_EXTRA_JS = 4.5;
  const NORMAL_A = (360 - (360 / total + GD_EXTRA_JS)) / (total - 1);
  const GD_A = 360 / total + GD_EXTRA_JS;

  if (container && sceneEl) {
    let rotation = 0, velocity = 0, isDragging = false, lastX = 0;

    function getAngle(i: number): number {
      let angle = 0;
      for (let j = 0; j < i; j++) {
        angle += (j === GD_I) ? GD_A : NORMAL_A;
      }
      return angle;
    }

    function updateCards() {
      cards.forEach((card, i) => {
        const cardAngle = getAngle(i);
        let diff = ((cardAngle + rotation) % 360 + 360) % 360;
        if (diff > 180) diff = 360 - diff;
        const t = diff / 180;
        const scale = 1.0 - t * 0.45;
        const opacity = 1.0 - t * 0.6;
        const brightness = 1.0 - t * 0.5;
        const el = card as HTMLElement;
        el.style.transform = `rotateY(${cardAngle}deg) translateZ(${R}px) scale(${scale})`;
        el.style.opacity = String(opacity);
        el.style.filter = `brightness(${brightness})`;
      });
    }

    sceneEl.addEventListener('wheel', (e) => { e.preventDefault(); velocity += e.deltaY * 0.3; }, { passive: false });
    sceneEl.addEventListener('mousedown', (e) => { isDragging = true; lastX = e.clientX; });
    window.addEventListener('mousemove', (e) => { if (!isDragging) return; velocity += (e.clientX - lastX) * 0.8; lastX = e.clientX; }, { passive: true });
    window.addEventListener('mouseup', () => { isDragging = false; });
    sceneEl.addEventListener('touchstart', (e) => { lastX = e.touches[0].clientX; }, { passive: true });
    sceneEl.addEventListener('touchmove', (e) => { velocity += (e.touches[0].clientX - lastX) * 0.8; lastX = e.touches[0].clientX; }, { passive: true });

    function loop() {
      velocity *= 0.94;
      rotation += velocity * 0.01;
      container.style.transform = `rotateX(8deg) rotateY(${rotation}deg)`;
      updateCards();
      requestAnimationFrame(loop);
    }
    loop();
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      if (lbImg) lbImg.src = card.getAttribute('data-src') || '';
      if (lbCaption) lbCaption.textContent = card.getAttribute('data-caption') || '';
      lightbox?.classList.add('active');
    });
  });
  lbClose?.addEventListener('click', () => lightbox?.classList.remove('active'));
  lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) lightbox.classList.remove('active'); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') lightbox?.classList.remove('active'); });
</script>
