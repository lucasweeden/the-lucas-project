<!-- Change 1: LP logo INSIDE the circle ring, consolidated into one element -->
<div id="lp-cursor" style="position:fixed;z-index:99999;pointer-events:none;width:56px;height:56px;border:2px solid #5aba32;border-radius:50%;transform:translate(-50%,-50%);transition:width 0.2s ease,height 0.2s ease,border-color 0.2s ease;">
  <img src="/images/smallLucas_Project_Logo.png" alt="" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:32px;height:32px;border-radius:50%;pointer-events:none;transition:width 0.2s ease,height 0.2s ease;" id="lp-cursor-img" />
</div>

<style is:global>
  * { cursor: none !important; }
</style>

<script is:inline>
  (function() {
    if (window.matchMedia('(pointer: fine)').matches && window.innerWidth > 768) {
      var el = document.getElementById('lp-cursor');
      var img = document.getElementById('lp-cursor-img');
      var mx = 0, my = 0, cx = 0, cy = 0;

      document.addEventListener('mousemove', function(e) {
        mx = e.clientX; my = e.clientY;
      });

      var hoverSel = 'a, button, .carousel-card, .card, .social-card, .btn-ghost, .contact-email-btn, .footer-social-pill';
      document.addEventListener('mouseover', function(e) {
        if (e.target && e.target.closest && e.target.closest(hoverSel) && el) {
          el.style.width = '70px'; el.style.height = '70px'; el.style.borderColor = '#8cd867';
          if (img) { img.style.width = '38px'; img.style.height = '38px'; }
        }
      });
      document.addEventListener('mouseout', function(e) {
        if (e.target && e.target.closest && e.target.closest(hoverSel) && el) {
          el.style.width = '56px'; el.style.height = '56px'; el.style.borderColor = '#5aba32';
          if (img) { img.style.width = '32px'; img.style.height = '32px'; }
        }
      });

      function anim() {
        cx += (mx - cx) * 0.12;
        cy += (my - cy) * 0.12;
        if (el) { el.style.left = cx + 'px'; el.style.top = cy + 'px'; }
        requestAnimationFrame(anim);
      }
      anim();
    } else {
      var el = document.getElementById('lp-cursor');
      if (el) el.style.display = 'none';
    }
  })();
</script>
