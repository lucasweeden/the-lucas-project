---
---
<section class="site-section" id="ventures">
  <div class="section-inner">
    <div class="section-label">06 — The Brands</div>
    <h2 class="section-title">CURRENT & FUTURE</h2>
    <div class="four-col">
      <a href="https://limitlessroofingsolutions.com" target="_blank" rel="noopener" class="card tilt-card" style="text-decoration:none; color: var(--text);">
        <img src="/images/Limitless_Roofing_Solutions_-_4.png" alt="Limitless Roofing Solutions" class="card-logo" loading="lazy" />
        <div class="card-title">Limitless Roofing Solutions</div>
        <div class="card-body">AI CRM, automation workflows, Lead Secure System. Built from 6 years in the field.</div>
        <span class="card-badge green">Active</span>
      </a>
      <div class="card tilt-card">
        <img src="/images/ai-learning-communities-logo.png" alt="AI Learning Communities" class="card-logo" style="width: 80px; height: auto; border-radius: 4px;" loading="lazy" />
        <div class="card-title">AI Learning Communities</div>
        <div class="card-body">AI education and community for real-world business application. Launching now.</div>
        <span class="card-badge green">Active — Launching</span>
      </div>
      <div class="card tilt-card">
        <img src="/images/smallLucas_Project_Logo.png" alt="The Lucas Project" class="card-logo" />
        <div class="card-title">The Lucas Project</div>
        <div class="card-body">The hub. Documenting the build in public across YouTube, Instagram, and TikTok. All roads lead here.</div>
        <span class="card-badge green">Active</span>
      </div>
      <!-- SDE with scratch-to-reveal -->
      <div class="card tilt-card" style="position:relative;overflow:hidden;" id="sde-card-wrap">
        <div class="sde-coming-soon">COMING SOON</div>
        <canvas id="sde-scratch" style="position:absolute;top:0;left:0;width:100%;height:100%;z-index:10;border-radius:16px;"></canvas>
        <div style="display:inline-block;background:#000;border-radius:10px;padding:10px;margin-bottom:16px;">
          <img src="/images/sde-logo.png" alt="Scurvy Dog Empire" style="filter:invert(1);width:60px;height:60px;object-fit:contain;display:block;" loading="lazy" />
        </div>
        <div class="card-title">Scurvy Dog Empire</div>
        <div class="card-body">Lifestyle clothing brand. Bold, unapologetic, personality-driven.</div>
        <span class="card-badge coral">Coming Soon</span>
      </div>
    </div>
  </div>
</section>

<style>
  .sde-coming-soon {
    position: absolute; top: -18px; left: 50%; transform: translateX(-50%);
    font-family: 'Syne', sans-serif; font-size: 10px; letter-spacing: 3px;
    color: rgba(140,216,103,0.35); z-index: 15; white-space: nowrap;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const sdeWrap = document.getElementById('sde-card-wrap');
  const sdeScratch = document.getElementById('sde-scratch') as HTMLCanvasElement;

  if (sdeWrap && sdeScratch) {
    let sdeRevealed = false;

    function setupSdeScratch() {
      if (sdeRevealed) return;
      const rect = sdeWrap.getBoundingClientRect();
      const w = rect.width, h = rect.height;
      sdeScratch.width = w; sdeScratch.height = h;
      sdeScratch.style.display = 'block';

      const ctx = sdeScratch.getContext('2d');
      if (!ctx) return;

      ctx.fillStyle = '#0a1a05';
      ctx.fillRect(0, 0, w, h);
      ctx.strokeStyle = 'rgba(58,122,42,0.1)';
      ctx.lineWidth = 1;
      for (let i = -h; i < w + h; i += 16) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i - h, h); ctx.stroke();
      }
      ctx.strokeStyle = '#3a7a2a'; ctx.lineWidth = 2;
      ctx.strokeRect(1, 1, w - 2, h - 2);

      ctx.fillStyle = '#5aba32';
      ctx.font = "bold 32px 'Bebas Neue', Impact, sans-serif";
      ctx.textAlign = 'center';
      ctx.fillText('DRAG TO REVEAL', w / 2, h * 0.42);
      ctx.fillStyle = 'rgba(140,216,103,0.6)';
      ctx.font = "13px 'Syne', sans-serif";
      ctx.fillText('scratch to uncover', w / 2, h * 0.56);

      function erase(e: MouseEvent | TouchEvent) {
        if (sdeRevealed) return;
        const cr = sdeScratch.getBoundingClientRect();
        let x: number, y: number;
        if ('touches' in e) { x = e.touches[0].clientX - cr.left; y = e.touches[0].clientY - cr.top; }
        else { x = e.clientX - cr.left; y = e.clientY - cr.top; }
        ctx.globalCompositeOperation = 'destination-out';
        ctx.beginPath(); ctx.arc(x, y, 35, 0, Math.PI * 2); ctx.fill();
        ctx.globalCompositeOperation = 'source-over';
      }
      sdeScratch.addEventListener('mousemove', erase);
      sdeScratch.addEventListener('touchmove', erase, { passive: true });

      const check = setInterval(() => {
        if (sdeRevealed) { clearInterval(check); return; }
        const d = ctx.getImageData(0, 0, w, h);
        let t = 0;
        for (let i = 3; i < d.data.length; i += 16) { if (d.data[i] === 0) t++; }
        if (t / Math.ceil(d.data.length / 16) > 0.55) {
          sdeRevealed = true; clearInterval(check);
          gsap.to(sdeScratch, { opacity: 0, duration: 0.5, onComplete: () => sdeScratch.remove() });
        }
      }, 200);
    }

    ScrollTrigger.create({
      trigger: sdeWrap, start: 'top 80%',
      onEnter: () => setupSdeScratch(),
    });
  }
</script>
