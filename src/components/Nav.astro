---
const links = [
  { href: "/", label: "Home", isHome: true },
  { href: "/#about", label: "About" },
  { href: "/#building", label: "Work" },
  { href: "/#story", label: "Story" },
  { href: "/#ventures", label: "Ventures" },
  { href: "/resources", label: "Resources" },
];
---
<nav class="site-nav" id="site-nav">
  <div class="nav-left">
    <a href="/" style="display:flex;align-items:center;gap:12px;text-decoration:none;">
      <img src="/images/smallLucas_Project_Logo.png" alt="LP" class="nav-logo" />
      <span class="nav-name">Lucas Weeden</span>
    </a>
  </div>
  <div class="nav-center">
    {links.map((l) => (
      <div class="nav-pill">
        <a href={l.href} class={`nav-pill-inner ${l.isHome ? 'nav-pill-home' : ''}`}>
          <span class={`nav-pill-front ${l.isHome ? 'nav-home-front' : ''}`}>{l.label}</span>
          <span class={`nav-pill-back ${l.isHome ? 'nav-home-back' : ''}`}>{l.label}</span>
        </a>
      </div>
    ))}
  </div>
  <div class="nav-right">
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-nav" id="mobile-nav">
  {links.map((l) => (
    <a href={l.href} class="mobile-nav-link">{l.label}</a>
  ))}
</div>

<style>
  .nav-home-front { background: #3a7a2a !important; color: #e8f5e0 !important; border-color: #3a7a2a !important; }
  .nav-home-back { background: #2d8a22 !important; }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');

  window.addEventListener('scroll', () => {
    if (window.scrollY > window.innerHeight * 0.8) nav?.classList.add('scrolled');
    else nav?.classList.remove('scrolled');
  });

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('active');
    mobileNav?.classList.toggle('active');
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('active');
      mobileNav?.classList.remove('active');
    });
  });
</script>
