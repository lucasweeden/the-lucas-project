---
const timeline = [
  { title: "Born Against The Odds", photo: "IMG_2282.jpeg", text: "Wasn't supposed to be born — both parents were using protection. Born in Oceanside, CA. Learned to swim before I could walk. Moved to Texas at age 2." },
  { title: "The Early Hustle", photo: "IMG_2829.jpeg", text: "By age 10, doing door-to-door sales splitting firewood profits with my great-grandfather. Candy business clearing $1K+/week in middle school. Learned early: positivity always wins." },
  { title: "High School Years", photo: "IMG_1218.PNG", text: "Tackle football ages 5–18. Six concussions. Still holds a discus record. Lawn care, reselling, party promoting, Dominos. Senior year: 40+ hours/week while doing school and sports full time." },
  { title: "The Leap At 19", photo: "IMG_1426.jpeg", text: "Same week: quit Dominos, got hired at Holden Roofing, bought a new car, signed a new apartment lease — with only a couple thousand dollars to my name. Sat down with my mom and laid out the whole plan. She gave me the push I needed. First month: $450K. All-time record. Still unbroken." },
  { title: "Building The Career", photo: "FullSizeRender.jpg", text: "$10M+ across 6 years. Co-founded Screaming Eagle Construction — $250K+ profit year one. Priority Roofing: Training MVP, highest commission per job company-wide. Multiple $1M+ months." },
  { title: "The Crash", photo: "IMG_5426.jpeg", text: "Desert. Dirt bike. Full send. This photo was taken just days before the accident. Blew out the knee — ACL, MCL, LCL, meniscus, everything. Wheelchair. Couldn't get on a roof. Got on a computer instead." },
  { title: "The Pivot", photo: "IMG_1770.jpeg", text: "Forced into AI. Found my partner Chase. Built Limitless Roofing Solutions from scratch — an AI-powered CRM for the roofing industry. The setback became the setup." },
  { title: "Right Now", photo: "IMG_4848.jpeg", text: "Building in public. Documenting the climb. Living wide open. It's about that time." },
];
---
<section class="site-section" id="about">
  <div class="section-inner" id="about-content-wrapper">
    <div class="section-label">04 — The Man</div>
    <h2 class="section-title">ABOUT LUCAS</h2>
    <div class="two-col" style="margin-bottom: 60px;">
      <div>
        <div class="photo-3d">
          <img src="/images/IMG_4848.jpeg" alt="Lucas hiking with dogs" class="section-portrait" loading="lazy" />
          <div class="glare"></div>
        </div>
      </div>
      <div>
        <blockquote class="pull-quote">"I'd rather build something that scares me than settle for something that doesn't."</blockquote>
        <p style="font-size: 18px; line-height: 1.8; opacity: 0.85;">
          Builder, operator, creator. $10M+ in roof sales across six years in Texas. Co-founded two companies. Won training MVP out of thousands of reps. Set records that still stand. Then a dirt bike sent me to a wheelchair — which sent me to a computer — which sent me straight into AI. Limitless Roofing Solutions was built from that chair. Every chapter in this story was earned the hard way, not handed over. Based in Texas. Always building.
        </p>
        <div class="stats-bar">
          <div class="stat-item"><div class="stat-number" data-count="10">$0</div><div class="stat-label">Roof Sales (M+)</div></div>
          <div class="stat-item"><div class="stat-number" data-count="6">0</div><div class="stat-label">Years In The Game</div></div>
          <div class="stat-item"><div class="stat-number" data-count="3.2">$0</div><div class="stat-label">Best Year (M)</div></div>
        </div>
      </div>
    </div>

    <!-- Blend trigger sentinel -->
    <div id="staircase-trigger-sentinel"></div>
    <h3 class="section-title" style="font-size: clamp(36px, 5vw, 64px); text-align: center; margin-top: 80px;" id="story">HOW I GOT HERE</h3>
  </div>

  <!-- Staircase trigger zone for ScrollTrigger pin -->
  <div id="staircase-section" style="height:100vh;"></div>

  <!-- Full-screen Three.js canvas -->
  <canvas id="staircase-canvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:500;display:none;opacity:0;"></canvas>

  <!-- Step progress indicator -->
  <div id="step-indicator" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:502;font-family:'Syne',sans-serif;font-size:12px;letter-spacing:3px;color:rgba(140,216,103,0.6);display:none;text-transform:uppercase;">Step 1 of 8</div>

  <!-- Mobile fallback -->
  <div class="mobile-timeline" id="mobile-timeline">
    {timeline.map((entry) => (
      <div class="mobile-step">
        <img src={`/images/${entry.photo}`} alt={entry.title} loading="lazy" onerror="this.style.display='none'" />
        <h4>{entry.title}</h4>
        <p>{entry.text}</p>
      </div>
    ))}
  </div>
</section>

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const isMobile = window.innerWidth < 768;
  const mobileEl = document.getElementById('mobile-timeline');
  const stairSection = document.getElementById('staircase-section');
  const stairCanvas = document.getElementById('staircase-canvas') as HTMLCanvasElement;
  const siteNav = document.getElementById('site-nav');
  const stepIndicator = document.getElementById('step-indicator');

  if (isMobile) {
    if (stairSection) stairSection.style.display = 'none';
    if (mobileEl) mobileEl.style.display = 'block';
    document.querySelectorAll('.mobile-step').forEach((step) => {
      ScrollTrigger.create({ trigger: step, start: 'top 80%', onEnter: () => (step as HTMLElement).style.opacity = '1' });
    });
  } else {
    if (mobileEl) mobileEl.style.display = 'none';

    // Change 2: Blend trigger at 25% from top
    const sentinel = document.getElementById('staircase-trigger-sentinel');
    if (sentinel) {
      const blendObs = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          stairCanvas.style.display = 'block';
          gsap.to(stairCanvas, { opacity: 1, duration: 2.5, ease: 'power1.inOut' });
          gsap.to('#about-content-wrapper', { opacity: 0, duration: 1.8, ease: 'power1.in', delay: 0.4 });
          blendObs.disconnect();
        }
      }, { rootMargin: '-75% 0px 0px 0px', threshold: 0 });
      blendObs.observe(sentinel);
    }

    if (stairSection && stairCanvas) {
      // Change 3: Complete staircase rebuild
      const STEP_COUNT = 8;
      const SPIRAL_RADIUS = 3.2;
      const STEP_HEIGHT = 1.8;
      const STEP_ANGLE = 42;
      const TREAD_WIDTH = 3.0;
      const TREAD_DEPTH = 1.6;
      const TREAD_THICKNESS = 0.14;

      const stepData = [
        { photo: '/images/IMG_2282.jpeg', title: 'Born Against The Odds', body: "Wasn't supposed to be born — both parents were using protection. Born in Oceanside, CA. Learned to swim before I could walk. Moved to Texas at age 2." },
        { photo: '/images/IMG_2829.jpeg', title: 'The Early Hustle', body: "By age 10, doing door-to-door sales splitting firewood profits with my great-grandfather. Candy business clearing $1K+/week in middle school." },
        { photo: '/images/IMG_1218.PNG', title: 'High School Years', body: "Tackle football ages 5–18. Six concussions. Still holds a discus record. Senior year: 40+ hours/week while doing school and sports full time." },
        { photo: '/images/IMG_1426.jpeg', title: 'The Leap At 19', body: "Quit Dominos, hired at Holden Roofing, new car, new apartment — all in the same week. First month: $450K. All-time record. Still unbroken." },
        { photo: '/images/FullSizeRender.jpg', title: 'Building The Career', body: "$10M+ across 6 years. Co-founded Screaming Eagle Construction — $250K+ profit year one. Priority Roofing MVP." },
        { photo: '/images/IMG_5426.jpeg', title: 'The Crash', body: "Desert. Dirt bike. Full send. Blew out the knee — ACL, MCL, LCL, meniscus, everything. Wheelchair. Got on a computer instead." },
        { photo: '/images/IMG_1770.jpeg', title: 'The Pivot', body: "Forced into AI. Found Chase. Built Limitless Roofing Solutions from scratch — an AI-powered CRM for the roofing industry." },
        { photo: '/images/IMG_4848.jpeg', title: 'Right Now', body: "Building in public. Documenting the climb. Living wide open. It's about that time." },
      ];

      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x030a02);
      scene.fog = new THREE.FogExp2(0x030a02, 0.045);

      const camera = new THREE.PerspectiveCamera(72, window.innerWidth / window.innerHeight, 0.1, 80);
      camera.position.set(0, 6, 0);

      const renderer = new THREE.WebGLRenderer({ canvas: stairCanvas, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.2;

      // Lighting
      scene.add(new THREE.AmbientLight(0x0a2005, 0.6));
      const dirLight = new THREE.DirectionalLight(0x4a8a2a, 0.8);
      dirLight.position.set(2, 8, 2);
      scene.add(dirLight);

      const rimLight = new THREE.PointLight(0x1a5a08, 0.5, 20);
      rimLight.position.set(0, -(STEP_COUNT * STEP_HEIGHT) - 2, 0);
      scene.add(rimLight);

      // Central column
      const colGeo = new THREE.CylinderGeometry(0.22, 0.26, STEP_COUNT * STEP_HEIGHT + 4, 16);
      const colMat = new THREE.MeshStandardMaterial({ color: 0x0d2a08, roughness: 0.7, metalness: 0.3, emissive: 0x071a04, emissiveIntensity: 0.2 });
      const col = new THREE.Mesh(colGeo, colMat);
      col.position.y = -(STEP_COUNT * STEP_HEIGHT / 2);
      scene.add(col);

      // Column glow
      const glowGeo = new THREE.CylinderGeometry(0.23, 0.23, STEP_COUNT * STEP_HEIGHT, 16);
      const glowMat = new THREE.MeshBasicMaterial({ color: 0x2a6a15, transparent: true, opacity: 0.15, side: THREE.BackSide });
      const glowMesh = new THREE.Mesh(glowGeo, glowMat);
      glowMesh.position.y = col.position.y;
      scene.add(glowMesh);

      // Materials
      const riserMat = new THREE.MeshStandardMaterial({ color: 0x0a1a06, roughness: 0.9 });
      const railMat = new THREE.MeshStandardMaterial({ color: 0x3a7a2a, roughness: 0.4, metalness: 0.6, emissive: 0x1a4a0a, emissiveIntensity: 0.3 });

      // Build steps + camera path + step lights
      const cameraPathPoints: THREE.Vector3[] = [];
      const stepLights: THREE.PointLight[] = [];

      for (let i = 0; i <= STEP_COUNT * 20; i++) {
        const t = i / (STEP_COUNT * 20);
        const angle = t * STEP_COUNT * (STEP_ANGLE * Math.PI / 180);
        const y = 5.5 - t * (STEP_COUNT * STEP_HEIGHT + 2.5);
        const wr = SPIRAL_RADIUS * 0.42;
        cameraPathPoints.push(new THREE.Vector3(Math.cos(angle) * wr, y, Math.sin(angle) * wr));
      }
      const cameraPath = new THREE.CatmullRomCurve3(cameraPathPoints);

      // Build physical steps
      for (let i = 0; i < STEP_COUNT; i++) {
        const angle = i * (STEP_ANGLE * Math.PI / 180);
        const y = -i * STEP_HEIGHT;
        const sx = Math.cos(angle) * SPIRAL_RADIUS * 0.5;
        const sz = Math.sin(angle) * SPIRAL_RADIUS * 0.5;

        // Tread (top face gets photo texture later)
        const treadGeo = new THREE.BoxGeometry(TREAD_WIDTH, TREAD_THICKNESS, TREAD_DEPTH);
        const tread = new THREE.Mesh(treadGeo, riserMat); // placeholder, replaced async
        tread.position.set(sx, y, sz);
        tread.rotation.y = -angle;
        tread.receiveShadow = true;
        scene.add(tread);

        // Riser
        const riserGeo = new THREE.BoxGeometry(TREAD_WIDTH, STEP_HEIGHT * 0.65, 0.08);
        const riser = new THREE.Mesh(riserGeo, riserMat);
        riser.position.set(
          Math.cos(angle) * SPIRAL_RADIUS * 0.5,
          y - STEP_HEIGHT * 0.33,
          Math.sin(angle) * SPIRAL_RADIUS * 0.5
        );
        riser.rotation.y = -angle;
        scene.add(riser);

        // Step light
        const sl = new THREE.PointLight(0x4aba25, 0.4, 5.5);
        sl.position.set(sx, y + 0.8, sz);
        scene.add(sl);
        stepLights.push(sl);

        // Light above step to illuminate texture
        const topLight = new THREE.PointLight(0xffffff, 1.2, 4);
        topLight.position.set(sx, y + 2.2, sz);
        scene.add(topLight);

        // Load photo texture onto step top face
        (function(stepMesh: THREE.Mesh, idx: number) {
          const d = stepData[idx];
          const canvas2d = document.createElement('canvas');
          canvas2d.width = 1200; canvas2d.height = 750;
          const ctx = canvas2d.getContext('2d')!;

          // Background gradient
          const bg = ctx.createLinearGradient(0, 0, 0, 750);
          bg.addColorStop(0, '#0a1f06'); bg.addColorStop(1, '#060d04');
          ctx.fillStyle = bg; ctx.fillRect(0, 0, 1200, 750);

          // Border
          ctx.strokeStyle = '#3a7a2a'; ctx.lineWidth = 4; ctx.strokeRect(6, 6, 1188, 738);

          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.onload = () => {
            // Photo area
            ctx.save();
            ctx.beginPath(); ctx.rect(22, 22, 1156, 400); ctx.clip();
            const ia = img.naturalWidth / img.naturalHeight;
            let dw = 1156, dh = 1156 / ia;
            if (dh < 400) { dh = 400; dw = 400 * ia; }
            ctx.drawImage(img, 22 + (1156 - dw) / 2, 22 + (400 - dh) / 2, dw, dh);
            ctx.restore();

            // Gradient overlay
            const pg = ctx.createLinearGradient(0, 340, 0, 422);
            pg.addColorStop(0, 'rgba(6,13,4,0)'); pg.addColorStop(1, 'rgba(6,13,4,0.95)');
            ctx.fillStyle = pg; ctx.fillRect(22, 340, 1156, 82);

            // Divider
            ctx.fillStyle = '#3a7a2a'; ctx.fillRect(22, 426, 1156, 2);

            // Step number
            ctx.fillStyle = 'rgba(90,186,50,0.3)'; ctx.font = '13px sans-serif'; ctx.textAlign = 'left';
            ctx.fillText(`0${idx + 1} / 08`, 28, 456);

            // Title
            ctx.fillStyle = '#8cd867'; ctx.font = 'bold 52px sans-serif'; ctx.textAlign = 'center';
            ctx.fillText(d.title.toUpperCase(), 600, 510);

            // Body text
            ctx.fillStyle = '#a8d890'; ctx.font = '20px sans-serif';
            const words = d.body.split(' ');
            let line = '', cy = 555;
            for (const w of words) {
              const test = line + w + ' ';
              if (ctx.measureText(test).width > 1060 && line) { ctx.fillText(line.trim(), 600, cy); line = w + ' '; cy += 28; } else line = test;
            }
            if (line) ctx.fillText(line.trim(), 600, cy);

            // Corner accents
            ctx.strokeStyle = '#5aba32'; ctx.lineWidth = 2.5;
            [[10,10,1,1],[1190,10,-1,1],[10,740,1,-1],[1190,740,-1,-1]].forEach(([cx,cy2,dx,dy]) => {
              ctx.beginPath(); ctx.moveTo(cx,cy2); ctx.lineTo(cx+dx*22,cy2); ctx.moveTo(cx,cy2); ctx.lineTo(cx,cy2+dy*22); ctx.stroke();
            });

            const tex = new THREE.CanvasTexture(canvas2d);
            tex.colorSpace = THREE.SRGBColorSpace;
            const topMat = new THREE.MeshStandardMaterial({ map: tex, roughness: 0.6, metalness: 0.1 });
            stepMesh.material = [riserMat, riserMat, topMat, riserMat, riserMat, riserMat];
          };
          img.onerror = () => {
            ctx.fillStyle = '#8cd867'; ctx.font = 'bold 48px sans-serif'; ctx.textAlign = 'center';
            ctx.fillText(d.title.toUpperCase(), 600, 375);
            stepMesh.material = [riserMat, riserMat, new THREE.MeshStandardMaterial({ map: new THREE.CanvasTexture(canvas2d) }), riserMat, riserMat, riserMat];
          };
          img.src = d.photo;
        })(tread, i);
      }

      // Handrail
      const railPts: THREE.Vector3[] = [];
      for (let i = 0; i <= STEP_COUNT * 12; i++) {
        const t = i / (STEP_COUNT * 12);
        const a = t * STEP_COUNT * (STEP_ANGLE * Math.PI / 180);
        const y = -t * STEP_COUNT * STEP_HEIGHT + 1.0;
        railPts.push(new THREE.Vector3(Math.cos(a) * (SPIRAL_RADIUS + 0.2), y, Math.sin(a) * (SPIRAL_RADIUS + 0.2)));
      }
      if (railPts.length >= 2) {
        scene.add(new THREE.Mesh(new THREE.TubeGeometry(new THREE.CatmullRomCurve3(railPts), 200, 0.045, 8, false), railMat));
      }

      // Balusters
      for (let i = 0; i < STEP_COUNT; i++) {
        const a = i * (STEP_ANGLE * Math.PI / 180);
        const b = new THREE.Mesh(new THREE.CylinderGeometry(0.025, 0.025, 1.0, 8), railMat);
        b.position.set(Math.cos(a) * (SPIRAL_RADIUS + 0.1), -i * STEP_HEIGHT + 0.5, Math.sin(a) * (SPIRAL_RADIUS + 0.1));
        scene.add(b);
      }

      // Dust particles
      const dg = new THREE.BufferGeometry();
      const dp = new Float32Array(120 * 3);
      for (let i = 0; i < 120; i++) { dp[i*3]=(Math.random()-0.5)*12; dp[i*3+1]=Math.random()*-(STEP_COUNT*STEP_HEIGHT+2); dp[i*3+2]=(Math.random()-0.5)*12; }
      dg.setAttribute('position', new THREE.BufferAttribute(dp, 3));
      scene.add(new THREE.Points(dg, new THREE.PointsMaterial({ color: 0x5aba32, size: 0.03, transparent: true, opacity: 0.4, sizeAttenuation: true })));

      // Scroll binding
      const scrollData = { progress: 0 };
      ScrollTrigger.create({
        trigger: stairSection,
        start: 'top top',
        end: `+=${STEP_COUNT * window.innerHeight * 1.4}`,
        pin: true,
        scrub: 1.2,
        onEnter: () => {
          stairCanvas.style.display = 'block';
          if (stepIndicator) stepIndicator.style.display = 'block';
          if (siteNav) { siteNav.style.opacity = '0'; siteNav.style.pointerEvents = 'none'; }
        },
        onLeave: () => {
          stairCanvas.style.display = 'none';
          if (stepIndicator) stepIndicator.style.display = 'none';
          if (siteNav) { siteNav.style.opacity = '1'; siteNav.style.pointerEvents = 'auto'; }
        },
        onEnterBack: () => {
          stairCanvas.style.display = 'block';
          if (stepIndicator) stepIndicator.style.display = 'block';
          if (siteNav) { siteNav.style.opacity = '0'; siteNav.style.pointerEvents = 'none'; }
        },
        onLeaveBack: () => {
          stairCanvas.style.display = 'none';
          if (stepIndicator) stepIndicator.style.display = 'none';
          if (siteNav) { siteNav.style.opacity = '1'; siteNav.style.pointerEvents = 'auto'; }
        },
        onUpdate: (self) => { scrollData.progress = self.progress; }
      });

      function animate() {
        requestAnimationFrame(animate);
        const t = Math.max(0, Math.min(scrollData.progress, 0.999));

        const pos = cameraPath.getPoint(t);
        camera.position.copy(pos);
        // Walking sway
        camera.position.x += Math.sin(t * STEP_COUNT * Math.PI * 2.2) * 0.08;
        camera.position.y += Math.sin(t * STEP_COUNT * Math.PI * 4.4) * 0.04;

        // Look ahead
        const lookT = Math.min(t + 0.025, 1.0);
        const target = cameraPath.getPoint(lookT);
        target.y -= 0.6;
        camera.lookAt(target);

        // Step light brightening
        stepLights.forEach((light, i) => {
          const stepT = i / STEP_COUNT;
          const dist = Math.abs(t - stepT);
          light.intensity = dist < 0.15 ? 1.8 - dist * 8 : 0.4;
        });

        // Step indicator
        const currentStep = Math.min(Math.floor(t * STEP_COUNT) + 1, STEP_COUNT);
        if (stepIndicator) stepIndicator.textContent = `Step ${currentStep} of ${STEP_COUNT}`;

        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }
  }
</script>

<style>
  .mobile-timeline { display: none; }
  .mobile-step {
    border-left: 3px solid #3a7a2a;
    padding-left: 20px;
    margin-bottom: 40px;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .mobile-step img {
    width: 100%; height: 200px; object-fit: cover; border-radius: 8px; margin-bottom: 12px;
  }
  .mobile-step h4 {
    font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: #5aba32;
    text-transform: uppercase; margin-bottom: 8px;
  }
  .mobile-step p {
    font-family: 'Syne', sans-serif; font-size: 14px; line-height: 1.6; color: #c8e8b0;
  }
  @media (max-width: 768px) {
    #staircase-section { display: none !important; }
    .mobile-timeline { display: block !important; }
  }
</style>
