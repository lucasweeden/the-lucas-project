---
const timeline = [
  { title: "Born Against The Odds", photo: "IMG_2282.jpeg", text: "Born Oceanside CA, moved to Texas at age 2" },
  { title: "The Early Hustle", photo: "IMG_2829.jpeg", text: "Door-to-door sales at age 10, candy business making $1K+/week" },
  { title: "High School Years", photo: "IMG_1218.PNG", text: "Football from ages 5–18, 6 concussions, discus record" },
  { title: "The Leap At 19", photo: "IMG_1426.jpeg", text: "Quit Dominos, joined Holden Roofing. New car, new apartment same week. $450K first month — all-time record, still unbroken" },
  { title: "Building The Career", photo: "FullSizeRender.jpg", text: "$10M+ total career sales, co-founded Screaming Eagle, Priority Roofing MVP" },
  { title: "The Crash", photo: "IMG_5426.jpeg", text: "Dirt bike accident. ACL, MCL, LCL, meniscus — wheelchair" },
  { title: "The Pivot", photo: "IMG_1770.jpeg", text: "Forced into AI, found Chase, built Limitless Roofing Solutions" },
  { title: "Right Now", photo: "IMG_4848.jpeg", text: "Building in public, documenting the climb" },
];
---
<section class="site-section" id="about">
  <div class="section-inner" id="about-content-wrapper">
    <div class="section-label">04 — The Man</div>
    <h2 class="section-title">ABOUT LUCAS</h2>
    <div class="two-col" style="margin-bottom: 60px;">
      <div>
        <div class="photo-3d">
          <img src="/images/IMG_4848.jpeg" alt="Lucas hiking with dogs" class="section-portrait" loading="lazy" />
          <div class="glare"></div>
        </div>
      </div>
      <div>
        <blockquote class="pull-quote">"I'd rather build something that scares me than settle for something that doesn't."</blockquote>
        <p style="font-size: 18px; line-height: 1.8; opacity: 0.85;">
          Builder, operator, creator. $10M+ in roof sales across six years in Texas. Co-founded two companies. Won training MVP out of thousands of reps. Set records that still stand. Then a dirt bike sent me to a wheelchair — which sent me to a computer — which sent me straight into AI. Limitless Roofing Solutions was built from that chair. Every chapter in this story was earned the hard way, not handed over. Based in Texas. Always building.
        </p>
        <div class="stats-bar">
          <div class="stat-item"><div class="stat-number" data-count="10">$0</div><div class="stat-label">Roof Sales (M+)</div></div>
          <div class="stat-item"><div class="stat-number" data-count="6">0</div><div class="stat-label">Years In The Game</div></div>
          <div class="stat-item"><div class="stat-number" data-count="3.2">$0</div><div class="stat-label">Best Year (M)</div></div>
        </div>
      </div>
    </div>
    <div id="staircase-trigger-sentinel"></div>
    <h3 class="section-title" style="font-size: clamp(36px, 5vw, 64px); text-align: center; margin-top: 80px;" id="story">HOW I GOT HERE</h3>
  </div>

  <div id="staircase-section" style="height:100vh;"></div>
  <canvas id="staircase-canvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:500;display:none;opacity:0;"></canvas>

  <!-- HTML overlay cards — centered in viewport when active -->
  <div id="staircase-overlays" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:501;pointer-events:none;display:none;">
    {timeline.map((entry, i) => (
      <div class="stair-overlay-card" id={`overlay-${i}`}>
        <img src={`/images/${entry.photo}`} alt={entry.title} loading="lazy" onerror="this.style.display='none'" />
        <div class="stair-overlay-title">{entry.title}</div>
        <div class="stair-overlay-desc">{entry.text}</div>
      </div>
    ))}
  </div>

  <div id="step-indicator" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:502;font-family:'Syne',sans-serif;font-size:12px;letter-spacing:3px;color:#5aba32;display:none;text-transform:uppercase;">STEP 1 OF 8</div>

  <div class="mobile-timeline" id="mobile-timeline">
    {timeline.map((entry) => (
      <div class="mobile-step">
        <img src={`/images/${entry.photo}`} alt={entry.title} loading="lazy" onerror="this.style.display='none'" />
        <h4>{entry.title}</h4>
        <p>{entry.text}</p>
      </div>
    ))}
  </div>
</section>

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const isMobile = window.innerWidth < 768;
  const mobileEl = document.getElementById('mobile-timeline');
  const stairSection = document.getElementById('staircase-section');
  const stairCanvas = document.getElementById('staircase-canvas') as HTMLCanvasElement;
  const overlaysWrap = document.getElementById('staircase-overlays');
  const siteNav = document.getElementById('site-nav');
  const stepIndicator = document.getElementById('step-indicator');

  if (isMobile) {
    if (stairSection) stairSection.style.display = 'none';
    if (mobileEl) mobileEl.style.display = 'block';
    document.querySelectorAll('.mobile-step').forEach((step) => {
      ScrollTrigger.create({ trigger: step, start: 'top 80%', onEnter: () => (step as HTMLElement).style.opacity = '1' });
    });
  } else {
    if (mobileEl) mobileEl.style.display = 'none';

    const sentinel = document.getElementById('staircase-trigger-sentinel');
    if (sentinel) {
      const blendObs = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          stairCanvas.style.display = 'block';
          if (overlaysWrap) overlaysWrap.style.display = 'block';
          gsap.to(stairCanvas, { opacity: 1, duration: 2.5, ease: 'power1.inOut' });
          gsap.to('#about-content-wrapper', { opacity: 0, duration: 1.8, ease: 'power1.in', delay: 0.4 });
          blendObs.disconnect();
        }
      }, { rootMargin: '-75% 0px 0px 0px', threshold: 0 });
      blendObs.observe(sentinel);
    }

    if (stairSection && stairCanvas) {
      const STEPS = 8;
      const STEP_DROP = 2.4;
      const STEP_TURN = -45;
      const STAIR_R = 3.0;
      const STEP_W = 3.2;
      const STEP_D = 1.6;
      const STEP_H = 0.18;
      const TOTAL_H = STEPS * STEP_DROP;

      // --- SCENE ---
      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x020804);
      // No fog — it was tinting photo textures green even on MeshBasicMaterial
      // scene.fog removed entirely

      const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 100);

      const renderer = new THREE.WebGLRenderer({ canvas: stairCanvas, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      // NO tone mapping — photos render in true sRGB colors
      renderer.toneMapping = THREE.NoToneMapping;
      renderer.outputColorSpace = THREE.SRGBColorSpace;
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;

      // --- COLUMN ---
      const colMat = new THREE.MeshStandardMaterial({ color: 0x1a4d0a, roughness: 0.6, metalness: 0.4, emissive: 0x0a2a06, emissiveIntensity: 0.3 });
      const col = new THREE.Mesh(new THREE.CylinderGeometry(0.35, 0.4, TOTAL_H + 4, 24), colMat);
      col.position.y = -TOTAL_H / 2 + 1;
      scene.add(col);

      // --- HANDRAIL ---
      const railPts: THREE.Vector3[] = [];
      for (let i = 0; i <= STEPS * 20; i++) {
        const t = i / (STEPS * 20);
        const ang = t * STEPS * (STEP_TURN * Math.PI / 180);
        railPts.push(new THREE.Vector3(Math.cos(ang) * (STAIR_R + 0.2), -t * TOTAL_H + 1.2, Math.sin(ang) * (STAIR_R + 0.2)));
      }
      scene.add(new THREE.Mesh(
        new THREE.TubeGeometry(new THREE.CatmullRomCurve3(railPts), 200, 0.05, 8, false),
        new THREE.MeshStandardMaterial({ color: 0x3a7a2a, roughness: 0.3, metalness: 0.7, emissive: 0x1a4a0a, emissiveIntensity: 0.5 })
      ));

      // --- BALUSTERS ---
      for (let i = 0; i < STEPS; i++) {
        const ang = i * (STEP_TURN * Math.PI / 180);
        const b = new THREE.Mesh(new THREE.CylinderGeometry(0.028, 0.028, 1.1, 8), new THREE.MeshStandardMaterial({ color: 0x2a5a1a }));
        b.position.set(Math.cos(ang) * (STAIR_R + 0.12), -i * STEP_DROP + 0.55, Math.sin(ang) * (STAIR_R + 0.12));
        scene.add(b);
      }

      // --- LIGHTING (EDIT 4A: white lights for true photo colors) ---
      scene.add(new THREE.AmbientLight(0xffffff, 0.7));
      const sun = new THREE.DirectionalLight(0xffffff, 0.9);
      sun.position.set(3, 15, 3);
      sun.castShadow = true;
      sun.shadow.mapSize.set(1024, 1024);
      scene.add(sun);

      // Subtle green accent at each step (low intensity, won't affect MeshBasicMaterial)
      const stepLights: { light: THREE.PointLight; idx: number }[] = [];
      for (let i = 0; i < STEPS; i++) {
        const ang = i * (STEP_TURN * Math.PI / 180);
        const pl = new THREE.PointLight(0x5aba32, 0.4, 6);
        pl.position.set(Math.cos(ang) * STAIR_R * 0.5, -i * STEP_DROP + 1.2, Math.sin(ang) * STAIR_R * 0.5);
        scene.add(pl);
        stepLights.push({ light: pl, idx: i });
      }

      // --- DUST ---
      const dg = new THREE.BufferGeometry();
      const dp = new Float32Array(300);
      for (let i = 0; i < 300; i += 3) { dp[i]=(Math.random()-0.5)*16; dp[i+1]=Math.random()*-(TOTAL_H+4); dp[i+2]=(Math.random()-0.5)*16; }
      dg.setAttribute('position', new THREE.BufferAttribute(dp, 3));
      scene.add(new THREE.Points(dg, new THREE.PointsMaterial({ color: 0x5aba32, size: 0.03, transparent: true, opacity: 0.3, sizeAttenuation: true })));

      // --- STEPS + PHOTO CARDS ---
      const treadMat = new THREE.MeshStandardMaterial({ color: 0x0d2006, roughness: 0.8 });
      const riserMat = new THREE.MeshStandardMaterial({ color: 0x071204, roughness: 0.9 });
      // Photo textures removed — photos now shown via HTML overlay cards for true colors

      for (let i = 0; i < STEPS; i++) {
        const ang = i * (STEP_TURN * Math.PI / 180);
        const cx = Math.cos(ang) * STAIR_R * 0.55;
        const cy = -i * STEP_DROP;
        const cz = Math.sin(ang) * STAIR_R * 0.55;

        // Tread
        const tread = new THREE.Mesh(new THREE.BoxGeometry(STEP_W, STEP_H, STEP_D), treadMat);
        tread.position.set(cx, cy, cz);
        tread.rotation.y = -ang;
        tread.receiveShadow = true;
        scene.add(tread);

        // Riser
        const riser = new THREE.Mesh(new THREE.BoxGeometry(STEP_W, STEP_DROP * 0.6, 0.08), riserMat);
        riser.position.set(cx, cy - STEP_DROP * 0.3, cz);
        riser.rotation.y = -ang;
        scene.add(riser);

        // Green edge glow
        const glow = new THREE.Mesh(new THREE.BoxGeometry(STEP_W, 0.015, 0.015), new THREE.MeshBasicMaterial({ color: 0x3a7a2a, transparent: true, opacity: 0.5 }));
        glow.position.set(cx, cy + STEP_H / 2, cz);
        glow.rotation.y = -ang;
        scene.add(glow);

        // Photos are rendered via HTML overlays (z-index 501) for perfect color accuracy
        // No 3D photo planes needed — the staircase geometry provides the visual backdrop
      }

      // --- CAMERA PATH (EDIT 4B: centered above, looking down, spiral descent) ---
      const scrollData = { progress: 0 };

      function updateCamera(t: number) {
        // Camera follows the spiral from slightly above each step, looking down at it
        // This gives a "walking down the staircase" POV centered on each step
        const currentStep = t * STEPS;
        const stepAng = currentStep * (STEP_TURN * Math.PI / 180);
        const stepY = -currentStep * STEP_DROP;

        // Camera position: on the spiral path, slightly above and inside the step radius
        // Positioned at the step but pulled inward toward center + raised above
        const camR = STAIR_R * 0.35; // close to center, looking outward at steps
        const camY = stepY + 3.0; // above the current step

        camera.position.set(
          Math.cos(stepAng) * camR,
          camY,
          Math.sin(stepAng) * camR
        );

        // Look at the current step position (where photos are mounted)
        const lookR = STAIR_R * 0.55;
        camera.lookAt(
          Math.cos(stepAng) * lookR,
          stepY,
          Math.sin(stepAng) * lookR
        );

        // Step light brightening
        stepLights.forEach(({ light, idx }) => {
          const stepT = idx / STEPS;
          const dist = Math.abs(t - stepT);
          light.intensity = dist < 0.15 ? 1.8 - dist * 8 : 0.3;
        });

        // HTML overlay visibility — centered in viewport, wider active window
        document.querySelectorAll('.stair-overlay-card').forEach((card, i) => {
          const el = card as HTMLElement;
          const stepT = i / STEPS;
          const dist = Math.abs(t - stepT);
          if (dist < 0.12) {
            // Fade in/out smoothly based on distance
            const fadeIn = 1 - (dist / 0.12);
            el.style.opacity = String(Math.max(0, fadeIn));
            el.style.transform = 'translate(-50%, -50%)';
          } else {
            el.style.opacity = '0';
            el.style.transform = 'translate(-50%, -40%)';
          }
        });

        const stepNum = Math.min(Math.floor(t * STEPS) + 1, STEPS);
        if (stepIndicator) stepIndicator.textContent = `STEP ${stepNum} OF ${STEPS}`;

        renderer.render(scene, camera);
      }

      // ScrollTrigger
      ScrollTrigger.create({
        trigger: stairSection,
        start: 'top top',
        end: `+=${STEPS * window.innerHeight * 1.5}`,
        pin: true,
        scrub: 1.2,
        onEnter: () => {
          stairCanvas.style.display = 'block';
          if (overlaysWrap) overlaysWrap.style.display = 'block';
          if (stepIndicator) stepIndicator.style.display = 'block';
          if (siteNav) { siteNav.style.opacity = '0'; siteNav.style.pointerEvents = 'none'; }
        },
        onLeave: () => {
          stairCanvas.style.display = 'none';
          if (overlaysWrap) overlaysWrap.style.display = 'none';
          if (stepIndicator) stepIndicator.style.display = 'none';
          if (siteNav) { siteNav.style.opacity = '1'; siteNav.style.pointerEvents = 'auto'; }
        },
        onEnterBack: () => {
          stairCanvas.style.display = 'block';
          if (overlaysWrap) overlaysWrap.style.display = 'block';
          if (stepIndicator) stepIndicator.style.display = 'block';
          if (siteNav) { siteNav.style.opacity = '0'; siteNav.style.pointerEvents = 'none'; }
        },
        onLeaveBack: () => {
          stairCanvas.style.display = 'none';
          if (overlaysWrap) overlaysWrap.style.display = 'none';
          if (stepIndicator) stepIndicator.style.display = 'none';
          if (siteNav) { siteNav.style.opacity = '1'; siteNav.style.pointerEvents = 'auto'; }
        },
        onUpdate: (self) => { scrollData.progress = self.progress; }
      });

      // Render loop with IntersectionObserver pause
      let visible = false;
      new IntersectionObserver(([e]) => { visible = e.isIntersecting; }, { threshold: 0.01 }).observe(stairSection);

      function animate() {
        requestAnimationFrame(animate);
        if (!visible) return;
        updateCamera(Math.max(0, Math.min(scrollData.progress, 0.999)));
      }
      animate();
      updateCamera(0);

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }
  }
</script>

<style>
  .stair-overlay-card {
    position: absolute;
    /* EDIT 4B: centered in viewport */
    left: 50%; top: 50%;
    transform: translate(-50%, -40%);
    width: 380px;
    background: rgba(0, 0, 0, 0.88);
    border: 1px solid rgba(90, 186, 50, 0.4);
    border-radius: 12px;
    padding: 18px;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }
  .stair-overlay-card img {
    width: 100%; height: 200px; object-fit: cover;
    border-radius: 8px; margin-bottom: 12px; display: block;
  }
  .stair-overlay-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px; color: #8cd867;
    text-transform: uppercase; letter-spacing: 0.04em;
    margin-bottom: 6px;
    background: rgba(0,0,0,0.85);
    display: inline-block; padding: 2px 12px; border-radius: 4px;
  }
  .stair-overlay-desc {
    font-size: 15px; line-height: 1.5;
    color: #a8d890; opacity: 0.9;
  }
  .mobile-timeline { display: none; }
  .mobile-step {
    border-left: 3px solid #3a7a2a; padding-left: 16px;
    margin-bottom: 48px; opacity: 0; transition: opacity 0.5s ease;
  }
  .mobile-step img { width: 100%; height: 220px; object-fit: cover; border-radius: 8px; margin-bottom: 12px; }
  .mobile-step h4 { font-family: 'Bebas Neue', sans-serif; font-size: 30px; color: #8cd867; text-transform: uppercase; margin-bottom: 8px; }
  .mobile-step p { font-family: 'Syne', sans-serif; font-size: 14px; line-height: 1.6; color: #a8d890; }
  @media (max-width: 768px) {
    #staircase-section { display: none !important; }
    .mobile-timeline { display: block !important; }
    .stair-overlay-card { width: 280px; }
  }
</style>
