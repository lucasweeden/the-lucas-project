---
const timeline = [
  { title: "Born Against The Odds", photo: "IMG_2282.jpeg", text: "Wasn't supposed to be born — both parents were using protection. Born in Oceanside, CA. Learned to swim before I could walk. Moved to Texas at age 2." },
  { title: "The Early Hustle", photo: "IMG_2829.jpeg", text: "By age 10, doing door-to-door sales splitting firewood profits with my great-grandfather. Candy business clearing $1K+/week in middle school. Learned early: positivity always wins." },
  { title: "High School Years", photo: "IMG_1218.PNG", text: "Tackle football ages 5–18. Six concussions. Still holds a discus record. Lawn care, reselling, party promoting, Dominos. Senior year: 40+ hours/week while doing school and sports full time." },
  { title: "The Leap At 19", photo: "IMG_1426.jpeg", text: "Same week: quit Dominos, got hired at Holden Roofing, bought a new car, signed a new apartment lease — with only a couple thousand dollars to my name. Sat down with my mom and laid out the whole plan. She gave me the push I needed. First month: $450K. All-time record. Still unbroken." },
  { title: "Building The Career", photo: "FullSizeRender.jpg", text: "$10M+ across 6 years. Co-founded Screaming Eagle Construction — $250K+ profit year one. Priority Roofing: Training MVP, highest commission per job company-wide. Multiple $1M+ months." },
  { title: "The Crash", photo: "IMG_5426.jpeg", text: "Desert. Dirt bike. Full send. This photo was taken just days before the accident. Blew out the knee — ACL, MCL, LCL, meniscus, everything. Wheelchair. Couldn't get on a roof. Got on a computer instead." },
  { title: "The Pivot", photo: "IMG_1770.jpeg", text: "Forced into AI. Found my partner Chase. Built Limitless Roofing Solutions from scratch — an AI-powered CRM for the roofing industry. The setback became the setup." },
  { title: "Right Now", photo: "IMG_4848.jpeg", text: "Building in public. Documenting the climb. Living wide open. It's about that time." },
];
---
<section class="site-section" id="about">
  <div class="section-inner" id="about-content-wrapper">
    <div class="section-label">04 — The Man</div>
    <h2 class="section-title">ABOUT LUCAS</h2>
    <div class="two-col" style="margin-bottom: 60px;">
      <div>
        <div class="photo-3d">
          <img src="/images/IMG_4848.jpeg" alt="Lucas hiking with dogs" class="section-portrait" loading="lazy" />
          <div class="glare"></div>
        </div>
      </div>
      <div>
        <blockquote class="pull-quote">"I'd rather build something that scares me than settle for something that doesn't."</blockquote>
        <p style="font-size: 18px; line-height: 1.8; opacity: 0.85;">
          Builder, operator, creator. $10M+ in roof sales across six years in Texas. Co-founded two companies. Won training MVP out of thousands of reps. Set records that still stand. Then a dirt bike sent me to a wheelchair — which sent me to a computer — which sent me straight into AI. Limitless Roofing Solutions was built from that chair. Every chapter in this story was earned the hard way, not handed over. Based in Texas. Always building.
        </p>
        <div class="stats-bar">
          <div class="stat-item"><div class="stat-number" data-count="10">$0</div><div class="stat-label">Roof Sales (M+)</div></div>
          <div class="stat-item"><div class="stat-number" data-count="6">0</div><div class="stat-label">Years In The Game</div></div>
          <div class="stat-item"><div class="stat-number" data-count="3.2">$0</div><div class="stat-label">Best Year (M)</div></div>
        </div>
      </div>
    </div>
    <div id="staircase-trigger-sentinel"></div>
    <h3 class="section-title" style="font-size: clamp(36px, 5vw, 64px); text-align: center; margin-top: 80px;" id="story">HOW I GOT HERE</h3>
  </div>

  <div id="staircase-section" style="height:100vh;"></div>
  <canvas id="staircase-canvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:500;display:none;opacity:0;"></canvas>
  <div id="step-indicator" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:502;font-family:'Syne',sans-serif;font-size:12px;letter-spacing:3px;color:#5aba32;display:none;text-transform:uppercase;">STEP 1 OF 8</div>

  <div class="mobile-timeline" id="mobile-timeline">
    {timeline.map((entry) => (
      <div class="mobile-step">
        <img src={`/images/${entry.photo}`} alt={entry.title} loading="lazy" onerror="this.style.display='none'" />
        <h4>{entry.title}</h4>
        <p>{entry.text}</p>
      </div>
    ))}
  </div>
</section>

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const isMobile = window.innerWidth < 768;
  const mobileEl = document.getElementById('mobile-timeline');
  const stairSection = document.getElementById('staircase-section');
  const stairCanvas = document.getElementById('staircase-canvas') as HTMLCanvasElement;
  const siteNav = document.getElementById('site-nav');
  const stepIndicator = document.getElementById('step-indicator');

  if (isMobile) {
    if (stairSection) stairSection.style.display = 'none';
    if (mobileEl) mobileEl.style.display = 'block';
    document.querySelectorAll('.mobile-step').forEach((step) => {
      ScrollTrigger.create({ trigger: step, start: 'top 80%', onEnter: () => (step as HTMLElement).style.opacity = '1' });
    });
  } else {
    if (mobileEl) mobileEl.style.display = 'none';

    // Blend trigger
    const sentinel = document.getElementById('staircase-trigger-sentinel');
    if (sentinel) {
      const blendObs = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          stairCanvas.style.display = 'block';
          gsap.to(stairCanvas, { opacity: 1, duration: 2.5, ease: 'power1.inOut' });
          gsap.to('#about-content-wrapper', { opacity: 0, duration: 1.8, ease: 'power1.in', delay: 0.4 });
          blendObs.disconnect();
        }
      }, { rootMargin: '-75% 0px 0px 0px', threshold: 0 });
      blendObs.observe(sentinel);
    }

    if (stairSection && stairCanvas) {
      const STEPS = 8;
      const STEP_DROP = 2.2;
      const STEP_TURN = -42; // negative = left turn
      const WALK_RADIUS = 3.96;
      const STEP_RADIUS = 2.8;
      const STEP_W = 3.4;
      const STEP_D = 1.8;
      const STEP_H = 0.16;

      const stepData = [
        { photo: '/images/IMG_2282.jpeg', title: 'Born Against The Odds', body: "Wasn't supposed to be born — both parents were using protection. Born in Oceanside, CA. Learned to swim before I could walk. Moved to Texas at age 2." },
        { photo: '/images/IMG_2829.jpeg', title: 'The Early Hustle', body: "By age 10, doing door-to-door sales splitting firewood profits with great-grandfather. Candy business clearing $1K+/week in middle school. Positivity always wins." },
        { photo: '/images/IMG_1218.PNG', title: 'High School Years', body: "Tackle football ages 5–18. Six concussions. Still holds a discus record. Senior year: 40+ hrs/week while doing school and sports." },
        { photo: '/images/IMG_1426.jpeg', title: 'The Leap At 19', body: "Same week: quit Dominos, hired at Holden Roofing, bought a car, signed an apartment. Sat down with mom and laid out the plan. First month: $450K. All-time record. Still unbroken." },
        { photo: '/images/FullSizeRender.jpg', title: 'Building The Career', body: "$10M+ across 6 years. Co-founded Screaming Eagle Construction — $250K+ profit year one. Priority Roofing MVP. Multiple $1M+ months." },
        { photo: '/images/IMG_5426.jpeg', title: 'The Crash', body: "Desert. Dirt bike. Full send. Days before the accident. Blew out the knee — ACL, MCL, LCL, meniscus. Wheelchair. Got on a computer instead." },
        { photo: '/images/IMG_1770.jpeg', title: 'The Pivot', body: "Forced into AI. Found Chase. Built Limitless Roofing Solutions — an AI-powered CRM for the roofing industry. The setback became the setup." },
        { photo: '/images/IMG_4848.jpeg', title: 'Right Now', body: "Building in public. Documenting the climb. Living wide open. It's about that time." },
      ];

      // Scene
      const scene = new THREE.Scene();
      scene.background = new THREE.Color(0x030a02);
      scene.fog = new THREE.FogExp2(0x030a02, 0.038);

      const camera = new THREE.PerspectiveCamera(95, window.innerWidth / window.innerHeight, 0.1, 80);
      camera.position.set(WALK_RADIUS, STEPS * STEP_DROP * 0.08, 0);

      const renderer = new THREE.WebGLRenderer({ canvas: stairCanvas, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.shadowMap.enabled = true;
      renderer.shadowMap.type = THREE.PCFSoftShadowMap;
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.1;

      // Column
      const col = new THREE.Mesh(
        new THREE.CylinderGeometry(0.2, 0.24, STEPS * STEP_DROP + 6, 16),
        new THREE.MeshStandardMaterial({ color: 0x0d2a08, roughness: 0.7, metalness: 0.3, emissive: 0x071a04, emissiveIntensity: 0.3 })
      );
      col.position.y = -(STEPS * STEP_DROP / 2);
      scene.add(col);

      // Handrail
      const railPts: THREE.Vector3[] = [];
      for (let i = 0; i <= STEPS * 16; i++) {
        const t = i / (STEPS * 16);
        const ang = t * STEPS * (STEP_TURN * Math.PI / 180);
        railPts.push(new THREE.Vector3(Math.cos(ang) * (STEP_RADIUS + 0.15), -t * STEPS * STEP_DROP + 1.05, Math.sin(ang) * (STEP_RADIUS + 0.15)));
      }
      const railMat = new THREE.MeshStandardMaterial({ color: 0x3a7a2a, roughness: 0.4, metalness: 0.6, emissive: 0x1a4a0a, emissiveIntensity: 0.4 });
      scene.add(new THREE.Mesh(new THREE.TubeGeometry(new THREE.CatmullRomCurve3(railPts), 200, 0.042, 8, false), railMat));

      // Balusters
      for (let i = 0; i < STEPS; i++) {
        const ang = i * (STEP_TURN * Math.PI / 180);
        const b = new THREE.Mesh(new THREE.CylinderGeometry(0.024, 0.024, 1.05, 8), new THREE.MeshStandardMaterial({ color: 0x2a5a1a, roughness: 0.5, metalness: 0.5 }));
        b.position.set(Math.cos(ang) * (STEP_RADIUS + 0.1), -i * STEP_DROP + 0.52, Math.sin(ang) * (STEP_RADIUS + 0.1));
        scene.add(b);
      }

      // Lighting
      scene.add(new THREE.AmbientLight(0x0a2005, 0.7));
      const sun = new THREE.DirectionalLight(0x4a8a2a, 0.9);
      sun.position.set(3, 10, 3);
      sun.castShadow = true;
      sun.shadow.mapSize.width = 1024;
      sun.shadow.mapSize.height = 1024;
      scene.add(sun);

      interface StepLight { light: THREE.PointLight; stepIndex: number; }
      const stepLightsArr: StepLight[] = [];
      for (let i = 0; i < STEPS; i++) {
        const ang = i * (STEP_TURN * Math.PI / 180);
        const pl = new THREE.PointLight(0x4aba25, 1.0, 6);
        pl.position.set(Math.cos(ang) * STEP_RADIUS * 0.45, -i * STEP_DROP + 1.2, Math.sin(ang) * STEP_RADIUS * 0.45);
        scene.add(pl);
        stepLightsArr.push({ light: pl, stepIndex: i });
      }
      scene.add(new THREE.PointLight(0x1a5a08, 0.4, 25));

      // Dust
      const dg = new THREE.BufferGeometry();
      const dp = new Float32Array(300);
      for (let i = 0; i < 300; i += 3) { dp[i] = (Math.random()-0.5)*14; dp[i+1] = Math.random()*-(STEPS*STEP_DROP+3); dp[i+2] = (Math.random()-0.5)*14; }
      dg.setAttribute('position', new THREE.BufferAttribute(dp, 3));
      scene.add(new THREE.Points(dg, new THREE.PointsMaterial({ color: 0x5aba32, size: 0.025, transparent: true, opacity: 0.35, sizeAttenuation: true })));

      // Step texture function
      const sideMat = new THREE.MeshStandardMaterial({ color: 0x0a1a06, roughness: 0.85 });
      const riserMat2 = new THREE.MeshStandardMaterial({ color: 0x071204, roughness: 0.9 });

      function makeStepTex(data: typeof stepData[0], idx: number): Promise<THREE.CanvasTexture> {
        return new Promise(resolve => {
          const C = document.createElement('canvas');
          C.width = 1024; C.height = 640;
          const ctx = C.getContext('2d')!;
          const bg = ctx.createLinearGradient(0,0,0,640);
          bg.addColorStop(0,'#0d2008'); bg.addColorStop(1,'#060d04');
          ctx.fillStyle = bg; ctx.fillRect(0,0,1024,640);
          ctx.strokeStyle = '#3a7a2a'; ctx.lineWidth = 5; ctx.strokeRect(4,4,1016,632);
          ctx.fillStyle = 'rgba(90,186,50,0.35)'; ctx.font = '500 14px Arial'; ctx.textAlign = 'right';
          ctx.fillText(`0${idx+1} / 08`, 1010, 30);

          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.onload = () => {
            ctx.save();
            ctx.beginPath(); ctx.rect(16, 16, 992, 356); ctx.clip();
            const ar = img.naturalWidth / img.naturalHeight;
            let dw = 992, dh = 992 / ar;
            if (dh < 356) { dh = 356; dw = 356 * ar; }
            ctx.drawImage(img, 16+(992-dw)/2, 16+(356-dh)/2, dw, dh);
            const fade = ctx.createLinearGradient(0,300,0,372);
            fade.addColorStop(0,'rgba(6,13,4,0)'); fade.addColorStop(1,'rgba(6,13,4,0.95)');
            ctx.fillStyle = fade; ctx.fillRect(16,300,992,72);
            ctx.restore();
            ctx.fillStyle = '#2a6a15'; ctx.fillRect(16,375,992,1.5);
            // Title with black backdrop
            const titleText = data.title.toUpperCase();
            ctx.font = 'bold 54px Arial'; ctx.textAlign = 'center';
            const titleW = ctx.measureText(titleText).width;
            ctx.fillStyle = 'rgba(0,0,0,0.85)';
            ctx.beginPath();
            ctx.rect(512 - titleW/2 - 20, 408, titleW + 40, 64);
            ctx.fill();
            ctx.fillStyle = '#8cd867';
            ctx.fillText(titleText, 512, 456);
            ctx.fillStyle = 'rgba(90,186,50,0.35)'; ctx.fillRect(312,472,400,1);
            ctx.fillStyle = '#a8d890'; ctx.font = '21px Arial'; ctx.textAlign = 'center';
            const words = data.body.split(' ');
            let line = '', y = 500, lh = 28, mw = 960;
            for (const w of words) {
              const t = line + w + ' ';
              if (ctx.measureText(t).width > mw && line) { ctx.fillText(line.trim(),512,y); line=w+' '; y+=lh; if(y>628)break; } else line=t;
            }
            if (line) ctx.fillText(line.trim(), 512, y);
            ctx.strokeStyle = '#5aba32'; ctx.lineWidth = 2;
            [[10,10,1],[1014,10,-1],[10,630,1],[1014,630,-1]].forEach(([x,yy,s]) => {
              ctx.beginPath(); ctx.moveTo(x,yy); ctx.lineTo(x+(s as number)*24,yy);
              ctx.moveTo(x,yy); ctx.lineTo(x,yy+((yy as number)<320?1:-1)*24); ctx.stroke();
            });
            resolve(new THREE.CanvasTexture(C));
          };
          img.onerror = () => {
            ctx.fillStyle = '#8cd867'; ctx.font = 'bold 48px Arial'; ctx.textAlign = 'center';
            ctx.fillText(data.title.toUpperCase(), 512, 320);
            resolve(new THREE.CanvasTexture(C));
          };
          img.src = data.photo;
        });
      }

      // Build steps
      async function buildSteps() {
        for (let i = 0; i < STEPS; i++) {
          const ang = i * (STEP_TURN * Math.PI / 180);
          const cx = Math.cos(ang) * (STEP_RADIUS * 0.5);
          const cy = -i * STEP_DROP;
          const cz = Math.sin(ang) * (STEP_RADIUS * 0.5);

          const tex = await makeStepTex(stepData[i], i);
          tex.colorSpace = THREE.SRGBColorSpace;
          const topMat = new THREE.MeshStandardMaterial({ map: tex, color: 0xffffff, roughness: 0.55, metalness: 0.08 });

          const treadGeo = new THREE.BoxGeometry(STEP_W, STEP_H, STEP_D);
          const tread = new THREE.Mesh(treadGeo, [sideMat, sideMat, topMat, riserMat2, sideMat, sideMat]);
          tread.position.set(cx, cy, cz);
          tread.rotation.y = -ang;
          tread.castShadow = true;
          tread.receiveShadow = true;
          scene.add(tread);

          const riser = new THREE.Mesh(
            new THREE.BoxGeometry(STEP_W, STEP_DROP * 0.65, 0.07),
            riserMat2
          );
          riser.position.set(cx, cy - STEP_DROP * 0.32, cz);
          riser.rotation.y = -ang;
          scene.add(riser);

          const glow = new THREE.Mesh(
            new THREE.BoxGeometry(STEP_W, 0.012, 0.012),
            new THREE.MeshBasicMaterial({ color: 0x3a7a2a, transparent: true, opacity: 0.6 })
          );
          glow.position.set(cx, cy + STEP_H / 2, cz);
          glow.rotation.y = -ang;
          scene.add(glow);
        }
      }

      // Camera path — left-turning spiral descent
      function buildCameraPath() {
        const pts: THREE.Vector3[] = [];
        const segs = STEPS * 24;
        for (let i = 0; i <= segs; i++) {
          const t = i / segs;
          const ang = t * STEPS * (STEP_TURN * Math.PI / 180);
          pts.push(new THREE.Vector3(
            Math.cos(ang) * WALK_RADIUS,
            STEP_DROP * 0.5 - t * (STEPS * STEP_DROP + STEP_DROP * 0.5),
            Math.sin(ang) * WALK_RADIUS
          ));
        }
        return new THREE.CatmullRomCurve3(pts);
      }

      // Initialize
      buildSteps().then(() => {
        const cameraPath = buildCameraPath();
        const scrollData = { progress: 0 };

        ScrollTrigger.create({
          trigger: stairSection,
          start: 'top top',
          end: `+=${STEPS * window.innerHeight * 1.5}`,
          pin: true,
          scrub: 1.0,
          onEnter: () => {
            stairCanvas.style.display = 'block';
            if (stepIndicator) stepIndicator.style.display = 'block';
            if (siteNav) { siteNav.style.opacity = '0'; siteNav.style.pointerEvents = 'none'; }
          },
          onLeave: () => {
            stairCanvas.style.display = 'none';
            if (stepIndicator) stepIndicator.style.display = 'none';
            if (siteNav) { siteNav.style.opacity = '1'; siteNav.style.pointerEvents = 'auto'; }
          },
          onEnterBack: () => {
            stairCanvas.style.display = 'block';
            if (stepIndicator) stepIndicator.style.display = 'block';
            if (siteNav) { siteNav.style.opacity = '0'; siteNav.style.pointerEvents = 'none'; }
          },
          onLeaveBack: () => {
            stairCanvas.style.display = 'none';
            if (stepIndicator) stepIndicator.style.display = 'none';
            if (siteNav) { siteNav.style.opacity = '1'; siteNav.style.pointerEvents = 'auto'; }
          },
          onUpdate: (self) => { scrollData.progress = self.progress; }
        });

        function animate() {
          requestAnimationFrame(animate);
          const t = Math.max(0, Math.min(scrollData.progress, 0.999));
          const pos = cameraPath.getPoint(t);
          camera.position.copy(pos);

          // Look ahead and DOWN at steps
          const lookT = Math.min(t + 0.03, 1.0);
          const lookPos = cameraPath.getPoint(lookT);
          lookPos.y -= 0.6;
          camera.lookAt(lookPos);

          // Walking sway
          camera.position.x += Math.sin(t * STEPS * Math.PI * 2.4) * 0.06;
          camera.position.y += Math.sin(t * STEPS * Math.PI * 4.8) * 0.03;

          // Step light brightening
          stepLightsArr.forEach(({ light, stepIndex }) => {
            const stepT = stepIndex / STEPS;
            const dist = Math.abs(t - stepT);
            light.intensity = dist < 0.18 ? Math.max(0, 2.2 - dist * 10) : 0.35;
          });

          const currentStep = Math.min(Math.floor(t * STEPS) + 1, STEPS);
          if (stepIndicator) stepIndicator.textContent = `STEP ${currentStep} OF ${STEPS}`;

          renderer.render(scene, camera);
        }
        animate();
        renderer.render(scene, camera);
      });

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }
  }
</script>

<style>
  .mobile-timeline { display: none; }
  .mobile-step {
    border-left: 3px solid #3a7a2a; padding-left: 16px;
    margin-bottom: 48px; opacity: 0; transition: opacity 0.5s ease;
  }
  .mobile-step img { width: 100%; height: 220px; object-fit: cover; border-radius: 8px; margin-bottom: 12px; }
  .mobile-step h4 { font-family: 'Bebas Neue', sans-serif; font-size: 30px; color: #8cd867; text-transform: uppercase; margin-bottom: 8px; }
  .mobile-step p { font-family: 'Syne', sans-serif; font-size: 14px; line-height: 1.6; color: #a8d890; }
  @media (max-width: 768px) {
    #staircase-section { display: none !important; }
    .mobile-timeline { display: block !important; }
  }
</style>
