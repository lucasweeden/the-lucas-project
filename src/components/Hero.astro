---
const tickerText = "THE LUCAS PROJECT · IT'S ABOUT THAT TIME · BUILDER · OPERATOR · CREATOR · ";
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/images/IMG_1530.jpeg" alt="" loading="eager" />
  </div>
  <canvas class="hero-canvas" id="hero-canvas"></canvas>
  <div class="hero-content">
    <div class="hero-label">THE LUCAS PROJECT</div>
    <div class="hero-title-line">LUCAS</div>
    <div class="hero-title-line hero-title-outline">WEEDEN</div>
    <div class="hero-tagline">Builder &middot; Operator &middot; Creator</div>
    <div class="hero-cta">
      <a href="#about" class="btn-ghost">Build your dreams or build someone else's</a>
    </div>
  </div>
  <div class="scroll-indicator">
    <span>Scroll</span>
    <div class="arrow"></div>
  </div>
  <div class="ticker-banner">
    <div class="ticker-track">
      {Array.from({ length: 8 }).map(() => (
        <span>{tickerText}</span>
      ))}
    </div>
  </div>
</section>

<img src="/images/smallLucas_Project_Logo.png" alt="" class="persistent-coin" id="persistent-coin" />

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Change 1: Bright lighting — true colors
    scene.add(new THREE.AmbientLight(0xffffff, 0.9));
    const dirLight = new THREE.DirectionalLight(0x8cd867, 1.8);
    dirLight.position.set(3, 4, 5);
    scene.add(dirLight);
    const ptLight = new THREE.PointLight(0x5aba32, 2.5, 25);
    ptLight.position.set(-2, 2, 4);
    scene.add(ptLight);

    const loader = new THREE.TextureLoader();
    const lpTex = loader.load('/images/smallLucas_Project_Logo.png');
    lpTex.colorSpace = THREE.SRGBColorSpace;

    // LP coin face material (shared)
    const faceMat = new THREE.MeshStandardMaterial({
      map: lpTex, color: 0xffffff, emissive: 0x2a5a1a, emissiveIntensity: 0.25,
      metalness: 0.35, roughness: 0.25, transparent: false
    });
    const rimMat = new THREE.MeshStandardMaterial({
      color: 0x3a7a2a, emissive: 0x1a4d0a, emissiveIntensity: 0.4,
      metalness: 0.4, roughness: 0.3
    });

    // Change 2: Main coin — large, bright
    const mainGeo = new THREE.CylinderGeometry(1.2, 1.2, 0.12, 64);
    const mainFace = faceMat.clone();
    mainFace.emissiveIntensity = 0.4;
    const coin = new THREE.Mesh(mainGeo, [rimMat.clone(), mainFace, mainFace.clone()]);

    // Intro: start offscreen above, small
    coin.position.y = 8;
    coin.scale.set(0.1, 0.1, 0.1);
    scene.add(coin);

    // Green halo rim glow
    const haloGeo = new THREE.CylinderGeometry(1.28, 1.28, 0.13, 64);
    const haloMat = new THREE.MeshBasicMaterial({ color: 0x5aba32, transparent: true, opacity: 0.35, side: THREE.BackSide });
    const halo = new THREE.Mesh(haloGeo, haloMat);
    scene.add(halo);
    halo.position.y = 8;
    halo.scale.set(0.1, 0.1, 0.1);

    // Background LP coins — all bright, no transparency
    interface BgCoin { mesh: THREE.Mesh; vx: number; vy: number; rotSpeed: number; baseX: number; baseY: number; }
    const bgCoins: BgCoin[] = [];
    const bgGeo = new THREE.CylinderGeometry(1, 1, 0.08, 32);

    for (let i = 0; i < 50; i++) {
      const s = 0.15 + Math.random() * 0.45;
      const bfm = faceMat.clone();
      const m = new THREE.Mesh(bgGeo, [rimMat.clone(), bfm, bfm.clone()]);
      m.scale.set(s, s, s);
      const x = (Math.random() - 0.5) * 16;
      const y = (Math.random() - 0.5) * 16;
      m.position.set(x, y, -5 - Math.random() * 10);
      m.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
      scene.add(m);
      // Point light near each bg coin
      const cl = new THREE.PointLight(0x5aba32, 0.15, 3);
      cl.position.set(x, y, m.position.z + 0.5);
      scene.add(cl);
      bgCoins.push({ mesh: m, vx: 0, vy: 0, rotSpeed: (Math.random() - 0.5) * 0.02, baseX: x, baseY: y });
    }

    let mouseNX = 0, mouseNY = 0;
    document.addEventListener('mousemove', (e) => {
      mouseNX = (e.clientX / window.innerWidth) * 2 - 1;
      mouseNY = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    let isVisible = true;
    const obs = new IntersectionObserver(([e]) => { isVisible = e.isIntersecting; }, { threshold: 0.1 });
    const heroEl = document.getElementById('hero');
    if (heroEl) obs.observe(heroEl);

    // Intro animation: fly in from above, 720 flip, then continuous spin
    let introComplete = false;
    setTimeout(() => {
      // Fly in
      gsap.to(coin.position, { y: 0, duration: 0.8, ease: 'power3.out' });
      gsap.to(coin.scale, { x: 1, y: 1, z: 1, duration: 0.8, ease: 'power3.out' });
      gsap.to(halo.position, { y: 0, duration: 0.8, ease: 'power3.out' });
      gsap.to(halo.scale, { x: 1, y: 1, z: 1, duration: 0.8, ease: 'power3.out' });
      // 720 flip after landing
      gsap.to(coin.rotation, { y: Math.PI * 4, duration: 1.0, ease: 'power2.inOut', delay: 0.8, onComplete: () => {
        introComplete = true;
        // Start continuous Y spin
        gsap.to(coin.rotation, { y: '+=6.283', duration: 2.0, ease: 'none', repeat: -1 });
      }});
    }, 2600);

    let time = 0;
    function animate() {
      requestAnimationFrame(animate);
      if (!isVisible) return;
      time += 0.016;

      if (introComplete) {
        // Multi-axis oscillation
        coin.rotation.x = Math.sin(time * 0.8) * 0.6 + mouseNY * 0.5;
        coin.rotation.z = Math.cos(time * 0.5) * 0.4 + mouseNX * 0.5;
      }
      halo.rotation.copy(coin.rotation);
      halo.position.copy(coin.position);

      bgCoins.forEach((bc) => {
        bc.mesh.rotation.y += bc.rotSpeed;
        bc.mesh.rotation.x += bc.rotSpeed * 0.5;
        const dx = bc.mesh.position.x - mouseNX * 5;
        const dy = bc.mesh.position.y - mouseNY * 5;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 3) {
          const f = (3 - dist) * 0.005;
          bc.vx += (dx / dist) * f;
          bc.vy += (dy / dist) * f;
        }
        bc.vx += (bc.baseX - bc.mesh.position.x) * 0.002;
        bc.vy += (bc.baseY - bc.mesh.position.y) * 0.002;
        bc.vx *= 0.98; bc.vy *= 0.98;
        bc.mesh.position.x += bc.vx;
        bc.mesh.position.y += bc.vy;
      });
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }

  // Persistent coin scroll
  const persistCoin = document.getElementById('persistent-coin');
  let coinFlicked = false;
  let lastSectionIdx = -1;
  window.addEventListener('scroll', () => {
    if (!persistCoin) return;
    if (window.scrollY > window.innerHeight * 0.8 && !coinFlicked) {
      coinFlicked = true;
      persistCoin.style.opacity = '1';
      gsap.fromTo(persistCoin, { bottom: '50vh', right: '50vw', width: 80, height: 80, scale: 1.3, rotateY: 0 },
        { bottom: 24, right: 24, width: 48, height: 48, scale: 1, rotateY: 360, duration: 0.8, ease: 'bounce.out', delay: 0.2 });
    }
    if (coinFlicked) {
      persistCoin.classList.add('visible');
      const sections = document.querySelectorAll('.site-section');
      let idx = 0;
      sections.forEach((s, i) => { if (s.getBoundingClientRect().top < window.innerHeight * 0.5) idx = i; });
      if (idx !== lastSectionIdx && lastSectionIdx >= 0) {
        gsap.to(persistCoin, { rotateY: '+=180', duration: 0.3, ease: 'power2.inOut' });
      }
      lastSectionIdx = idx;
    }
  });
</script>
