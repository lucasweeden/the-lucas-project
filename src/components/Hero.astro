---
const tickerText = "THE LUCAS PROJECT · IT'S ABOUT THAT TIME · BUILDER · OPERATOR · CREATOR · ";
---
<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/images/IMG_1530.jpeg" alt="" loading="eager" />
  </div>
  <canvas class="hero-canvas" id="hero-canvas"></canvas>
  <div class="hero-content">
    <div class="hero-label">THE LUCAS PROJECT</div>
    <div class="hero-title-line">LUCAS</div>
    <div class="hero-title-line hero-title-outline">WEEDEN</div>
    <div class="hero-tagline">Builder &middot; Operator &middot; Creator</div>
    <div class="hero-cta">
      <a href="#about" class="btn-ghost">Build your dreams or build someone else's</a>
    </div>
  </div>
  <div class="scroll-indicator">
    <span>Scroll</span>
    <div class="arrow"></div>
  </div>
  <div class="ticker-banner">
    <div class="ticker-track">
      {Array.from({ length: 8 }).map(() => (
        <span>{tickerText}</span>
      ))}
    </div>
  </div>
</section>

<img src="/images/smallLucas_Project_Logo.png" alt="" class="persistent-coin" id="persistent-coin" />

<script>
  import * as THREE from 'three';
  import { gsap } from 'gsap';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // LP brand lighting
    scene.add(new THREE.AmbientLight(0x1a4d0a, 0.4));
    const pl1 = new THREE.PointLight(0x5aba32, 2.0, 20);
    pl1.position.set(3, 3, 4);
    scene.add(pl1);
    const pl2 = new THREE.PointLight(0x8cd867, 1.0, 20);
    pl2.position.set(-3, -2, 3);
    scene.add(pl2);

    const loader = new THREE.TextureLoader();
    const logoTex = loader.load('/images/smallLucas_Project_Logo.png');
    logoTex.colorSpace = THREE.SRGBColorSpace;

    // Change 2: Large center coin — LP logo, infinite 360 flip
    const mainGeo = new THREE.CylinderGeometry(2.0, 2.0, 0.18, 64);
    const mainMats = [
      new THREE.MeshStandardMaterial({ color: 0x3a7a2a, metalness: 0.4, roughness: 0.3 }),
      new THREE.MeshStandardMaterial({ map: logoTex, metalness: 0.4, roughness: 0.3 }),
      new THREE.MeshStandardMaterial({ map: logoTex, metalness: 0.4, roughness: 0.3 }),
    ];
    const coin = new THREE.Mesh(mainGeo, mainMats);
    scene.add(coin);

    // Rim glow
    const glowGeo = new THREE.CylinderGeometry(2.2, 2.2, 0.22, 64);
    const glowMat = new THREE.MeshBasicMaterial({ color: 0x5aba32, transparent: true, opacity: 0.1, blending: THREE.AdditiveBlending });
    const glow = new THREE.Mesh(glowGeo, glowMat);
    scene.add(glow);

    // Infinite 360 flip via GSAP
    gsap.to(coin.rotation, { y: Math.PI * 2, duration: 2.5, ease: 'none', repeat: -1 });

    // Background LP logo coins
    interface BgCoin { mesh: THREE.Mesh; vx: number; vy: number; rotSpeed: number; baseX: number; baseY: number; }
    const bgCoins: BgCoin[] = [];
    const bgGeo = new THREE.CylinderGeometry(1, 1, 0.1, 32);

    for (let i = 0; i < 50; i++) {
      const scale = 0.15 + Math.random() * 0.45;
      const op = 0.3 + Math.random() * 0.5;
      const bgMat = [
        new THREE.MeshStandardMaterial({ color: 0x3a7a2a, metalness: 0.4, roughness: 0.3, transparent: true, opacity: op }),
        new THREE.MeshStandardMaterial({ map: logoTex, metalness: 0.4, roughness: 0.3, transparent: true, opacity: op }),
        new THREE.MeshStandardMaterial({ map: logoTex, metalness: 0.4, roughness: 0.3, transparent: true, opacity: op }),
      ];
      const m = new THREE.Mesh(bgGeo, bgMat);
      m.scale.set(scale, scale, scale);
      const x = (Math.random() - 0.5) * 16;
      const y = (Math.random() - 0.5) * 16;
      m.position.set(x, y, -5 - Math.random() * 10);
      m.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
      scene.add(m);
      bgCoins.push({ mesh: m, vx: 0, vy: 0, rotSpeed: (Math.random() - 0.5) * 0.02, baseX: x, baseY: y });
    }

    let mouseNX = 0, mouseNY = 0;
    document.addEventListener('mousemove', (e) => {
      mouseNX = (e.clientX / window.innerWidth) * 2 - 1;
      mouseNY = -(e.clientY / window.innerHeight) * 2 + 1;
    });

    let isVisible = true;
    const obs = new IntersectionObserver(([e]) => { isVisible = e.isIntersecting; }, { threshold: 0.1 });
    const heroEl = document.getElementById('hero');
    if (heroEl) obs.observe(heroEl);

    let time = 0;
    function animate() {
      requestAnimationFrame(animate);
      if (!isVisible) return;
      time += 0.016;

      // Wobble tilt + mouse tilt overlay (GSAP handles Y rotation)
      coin.rotation.x = Math.sin(time * 0.8) * 0.3 + mouseNY * 0.35;
      coin.rotation.z = mouseNX * 0.35;
      glow.rotation.copy(coin.rotation);

      bgCoins.forEach((bc) => {
        bc.mesh.rotation.y += bc.rotSpeed;
        bc.mesh.rotation.x += bc.rotSpeed * 0.5;
        const dx = bc.mesh.position.x - mouseNX * 5;
        const dy = bc.mesh.position.y - mouseNY * 5;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 3) {
          const f = (3 - dist) * 0.005;
          bc.vx += (dx / dist) * f;
          bc.vy += (dy / dist) * f;
        }
        bc.vx += (bc.baseX - bc.mesh.position.x) * 0.002;
        bc.vy += (bc.baseY - bc.mesh.position.y) * 0.002;
        bc.vx *= 0.98; bc.vy *= 0.98;
        bc.mesh.position.x += bc.vx;
        bc.mesh.position.y += bc.vy;
      });
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }

  // Persistent coin scroll behavior
  const persistCoin = document.getElementById('persistent-coin');
  let coinFlicked = false;
  let lastSectionIdx = -1;
  window.addEventListener('scroll', () => {
    if (!persistCoin) return;
    if (window.scrollY > window.innerHeight * 0.8 && !coinFlicked) {
      coinFlicked = true;
      persistCoin.style.opacity = '1';
      gsap.fromTo(persistCoin, { bottom: '50vh', right: '50vw', width: 80, height: 80, scale: 1.3, rotateY: 0 },
        { bottom: 24, right: 24, width: 48, height: 48, scale: 1, rotateY: 360, duration: 0.8, ease: 'bounce.out', delay: 0.2 });
    }
    if (coinFlicked) {
      persistCoin.classList.add('visible');
      const sections = document.querySelectorAll('.site-section');
      let idx = 0;
      sections.forEach((s, i) => { if (s.getBoundingClientRect().top < window.innerHeight * 0.5) idx = i; });
      if (idx !== lastSectionIdx && lastSectionIdx >= 0) {
        gsap.to(persistCoin, { rotateY: '+=180', duration: 0.3, ease: 'power2.inOut' });
      }
      lastSectionIdx = idx;
    }
  });
</script>
