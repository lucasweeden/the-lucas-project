---
interface Props {
  title?: string;
}
const { title = "Lucas Weeden — Builder · Operator · Creator" } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
  <title>{title}</title>
  <meta name="description" content="The Lucas Project — documenting the real-time build of businesses, brands, and a life lived wide open. $10M+ in sales, AI pivot, and always building." />
  <meta property="og:title" content="Lucas Weeden — The Lucas Project" />
  <meta property="og:description" content="Builder. Operator. Creator. It's about that time." />
  <meta property="og:url" content="https://lucasweeden.com" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://lucasweeden.com" />
  <link rel="icon" type="image/png" href="/images/smallLucas_Project_Logo.png" />
  <link rel="preload" href="/images/IMG_1530.jpeg" as="image" />
  <!-- Preload carousel images so they appear instantly on mobile -->
  <link rel="preload" href="/images/IMG_4863.jpeg" as="image" />
  <link rel="preload" href="/images/IMG_6652.jpeg" as="image" />
  <link rel="preload" href="/images/IMG_3496.jpeg" as="image" />
  <link rel="preload" href="/images/IMG_4898.jpeg" as="image" />
  <link rel="preload" href="/images/IMG_0717.jpeg" as="image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script is:inline>
    document.documentElement.setAttribute('data-theme', 'dark');
    // Device detection
    (function() {
      var ua = navigator.userAgent;
      var w = window.innerWidth;
      var d = 'desktop';
      if (/Mobi|Android|iPhone|iPod|BlackBerry|IEMobile|Opera Mini/i.test(ua) || w < 768) d = 'mobile';
      else if (/iPad|Tablet/i.test(ua) || (w >= 768 && w < 1200)) d = 'tablet';
      document.documentElement.setAttribute('data-device', d);
      document.documentElement.classList.add('device-' + d);
      sessionStorage.setItem('lp_device', d);
    })();

    // Force preload all site images on mobile/tablet so nothing fails to render
    (function() {
      var d = sessionStorage.getItem('lp_device');
      if (d === 'mobile' || d === 'tablet') {
        var imgs = [
          'IMG_4863.jpeg','IMG_1530.jpeg','IMG_6652.jpeg','IMG_3496.jpeg','IMG_4898.jpeg',
          'IMG_2047.jpeg','IMG_9474.jpeg','IMG_0717.jpeg','IMG_1001.jpeg','IMG_4459.jpeg',
          'IMG_2720.jpeg','IMG_4848.jpeg','IMG_0856.jpeg','IMG_1218.PNG','IMG_2829.jpeg',
          'IMG_0045.jpeg','IMG_5426.jpeg','IMG_2282.jpeg','IMG_4463.jpeg','IMG_1426.jpeg',
          'FullSizeRender.jpg','IMG_1770.jpeg','IMG_2282.jpeg','IMG_2829.jpeg',
          'IMG_1218.PNG','IMG_5426.jpeg','IMG_1770.jpeg','IMG_4848.jpeg'
        ];
        // Deduplicate
        var seen = {};
        imgs = imgs.filter(function(i) { if (seen[i]) return false; seen[i] = true; return true; });
        imgs.forEach(function(src) {
          var img = new Image();
          img.src = '/images/' + src;
        });
      }
    })();
  </script>
</head>
<body>
  <!-- Splash Screen -->
  <div id="lp-splash" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:#050f02;z-index:999999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;transition:opacity 600ms ease;">
    <div id="splash-coin-wrapper" style="width:180px;height:180px;border-radius:50%;transition:transform 200ms ease,box-shadow 200ms ease;">
      <img id="splash-coin" src="/images/smallLucas_Project_Logo.png" alt="The Lucas Project" style="width:100%;height:100%;border-radius:50%;display:block;" />
    </div>
    <p id="splash-prompt" style="font-family:'Bebas Neue',sans-serif;font-size:28px;color:#8cd867;letter-spacing:6px;margin:0;">CLICK TO ENTER</p>
    <p style="font-family:'Syne',sans-serif;font-size:12px;color:rgba(140,216,103,0.5);letter-spacing:4px;text-transform:uppercase;margin:0;">The Lucas Project</p>
  </div>

  <slot />

  <!-- Music Player Widget -->
  <div id="lp-music-player" style="position:fixed;top:72px;right:16px;z-index:10001;width:220px;height:64px;background:rgba(6,13,4,0.88);border:1px solid #3a7a2a;border-radius:32px;backdrop-filter:blur(12px);padding:10px 16px;display:flex;align-items:center;gap:8px;font-family:'Syne',sans-serif;">
    <button id="mp-prev" class="mp-btn" aria-label="Previous">⏮</button>
    <button id="mp-play" class="mp-btn" aria-label="Play">▶</button>
    <button id="mp-next" class="mp-btn" aria-label="Next">⏭</button>
    <div id="mp-track" style="flex:1;overflow:hidden;white-space:nowrap;font-size:11px;color:#8cd867;letter-spacing:0.5px;">
      <span id="mp-track-text">Ready</span>
    </div>
    <button id="mp-mute" class="mp-btn" aria-label="Mute">🔊</button>
  </div>

  <style is:inline>
    .mp-btn {
      width:28px;height:28px;border-radius:50%;
      background:rgba(90,186,50,0.15);border:1px solid #3a7a2a;color:#8cd867;
      font-size:12px;display:flex;align-items:center;justify-content:center;
      cursor:none;transition:background 150ms ease;flex-shrink:0;padding:0;
    }
    .mp-btn:hover { background:rgba(90,186,50,0.3); }
    #mp-track-text.scrolling { display:inline-block; animation:mpMarquee 8s linear infinite; }
    @keyframes mpMarquee { 0%{transform:translateX(0)} 100%{transform:translateX(-100%)} }
    @keyframes splashCoinSpin { 0%{transform:rotateY(0deg)} 100%{transform:rotateY(360deg)} }
    @keyframes splashPulse { from{box-shadow:0 0 40px #5aba32,0 0 80px rgba(90,186,50,0.2)} to{box-shadow:0 0 80px #8cd867,0 0 140px rgba(90,186,50,0.45)} }
    @keyframes splashBlink { from{opacity:0.5} to{opacity:1} }
    #splash-coin-wrapper { animation:splashCoinSpin 3s linear infinite, splashPulse 2s ease-in-out infinite alternate; }
    #splash-coin-wrapper:hover { transform:scale(1.08); box-shadow:0 0 80px #8cd867,0 0 160px rgba(90,186,50,0.5); }
    #splash-prompt { animation:splashBlink 1.5s ease-in-out infinite alternate; }
  </style>

  <script is:inline>
    (function() {
      var playlist = [
        '/audio/evgeny_bardyuzha-password-infinity-123276.mp3',
        '/audio/artissizm-drift-phonk-200108.mp3',
        '/audio/desifreemusic-90s-style-boom-bap-beat-with-dusty-vinyl-crackles-378424.mp3',
        '/audio/dferun-20s-swing-rave-480544.mp3',
        '/audio/fassounds-good-night-lofi-cozy-chill-music-160166%20(1).mp3',
        '/audio/lazarosv-cosmic-drift-ii-409679.mp3',
        '/audio/leberch-ambient-atmospheric-509533.mp3',
        '/audio/tunetank-melodic-type-beat-349530.mp3',
        '/audio/tunetank-presentation-beat-349420.mp3'
      ];

      var audio = new Audio();
      audio.volume = 0;
      var currentTrack = 0;
      var isPlaying = false;
      var musicStarted = false;

      var playBtn = document.getElementById('mp-play');
      var prevBtn = document.getElementById('mp-prev');
      var nextBtn = document.getElementById('mp-next');
      var muteBtn = document.getElementById('mp-mute');
      var trackText = document.getElementById('mp-track-text');
      var trackWrap = document.getElementById('mp-track');
      var splash = document.getElementById('lp-splash');

      function formatName(path) {
        var name = path.split('/').pop().replace(/\.[^.]+$/, '');
        name = decodeURIComponent(name);
        return name.replace(/[-_]/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
      }

      function updateTrackDisplay() {
        if (!trackText) return;
        var name = formatName(playlist[currentTrack]);
        trackText.textContent = name;
        trackText.className = '';
        setTimeout(function() {
          if (trackText.scrollWidth > (trackWrap ? trackWrap.clientWidth : 200)) {
            trackText.className = 'scrolling';
          }
        }, 50);
      }

      function updatePlayButton() {
        if (playBtn) playBtn.textContent = isPlaying ? '⏸' : '▶';
      }

      function loadTrack(index) {
        currentTrack = ((index % playlist.length) + playlist.length) % playlist.length;
        audio.src = playlist[currentTrack];
        audio.load();
        updateTrackDisplay();
      }

      function playTrack() {
        audio.play().catch(function() {});
        isPlaying = true;
        updatePlayButton();
      }

      function pauseTrack() {
        audio.pause();
        isPlaying = false;
        updatePlayButton();
      }

      function fadeIn() {
        audio.volume = 0;
        var fade = setInterval(function() {
          if (audio.volume < 0.20) {
            audio.volume = Math.min(audio.volume + 0.013, 0.20);
          } else {
            clearInterval(fade);
          }
        }, 100);
      }

      function hideSplash() {
        if (!splash) return;
        splash.style.opacity = '0';
        setTimeout(function() {
          splash.style.display = 'none';
          try { splash.remove(); } catch(e) {}
        }, 650);
      }

      function showSplash() {
        if (splash) splash.style.display = 'flex';
      }

      function onMusicStarted() {
        sessionStorage.setItem('lp_music_started', 'true');
      }

      function startMusicAndHideSplash() {
        if (musicStarted) return;
        musicStarted = true;
        var saved = sessionStorage.getItem('lp_music_track');
        var savedTime = sessionStorage.getItem('lp_music_time');
        if (saved !== null && parseInt(saved) > 0) {
          loadTrack(parseInt(saved));
          if (savedTime) audio.currentTime = parseFloat(savedTime);
        } else {
          loadTrack(0);
        }
        playTrack();
        fadeIn();
        hideSplash();
        onMusicStarted();
      }

      audio.addEventListener('ended', function() {
        var next = currentTrack === 0 ? 1 : (currentTrack + 1);
        if (next >= playlist.length) next = 1;
        loadTrack(next);
        playTrack();
      });

      // Check if already interacted this session
      if (sessionStorage.getItem('lp_music_started') === 'true') {
        // Skip splash, resume music
        hideSplash();
        var saved = sessionStorage.getItem('lp_music_track');
        var savedTime = sessionStorage.getItem('lp_music_time');
        if (saved !== null) loadTrack(parseInt(saved));
        else loadTrack(0);
        if (savedTime) audio.currentTime = parseFloat(savedTime);
        musicStarted = true;
        // Try autoplay (may work since user interacted before)
        audio.play().then(function() {
          isPlaying = true;
          updatePlayButton();
          fadeIn();
        }).catch(function() {
          // Need interaction again — listen for click
          document.addEventListener('click', function() {
            if (!isPlaying) { playTrack(); fadeIn(); }
          }, { once: true });
        });
      } else {
        // Fresh visit — try autoplay
        loadTrack(0);
        var attempt = audio.play();
        if (attempt !== undefined) {
          attempt.then(function() {
            // Autoplay succeeded
            musicStarted = true;
            isPlaying = true;
            updatePlayButton();
            fadeIn();
            hideSplash();
            onMusicStarted();
          }).catch(function() {
            // Autoplay blocked — show splash
            audio.pause();
            showSplash();
          });
        }
      }

      // Splash click handler
      if (splash) {
        splash.addEventListener('click', function() {
          startMusicAndHideSplash();
        });
      }

      // Player controls
      if (playBtn) playBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (!musicStarted) { startMusicAndHideSplash(); return; }
        if (isPlaying) { pauseTrack(); } else { playTrack(); }
      });

      if (nextBtn) nextBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (!musicStarted) startMusicAndHideSplash();
        var next = (currentTrack + 1) % playlist.length;
        loadTrack(next);
        playTrack();
      });

      if (prevBtn) prevBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (!musicStarted) startMusicAndHideSplash();
        var prev = (currentTrack - 1 + playlist.length) % playlist.length;
        loadTrack(prev);
        playTrack();
      });

      if (muteBtn) muteBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        audio.muted = !audio.muted;
        muteBtn.textContent = audio.muted ? '🔇' : '🔊';
        muteBtn.style.opacity = audio.muted ? '0.4' : '1';
      });

      window.addEventListener('beforeunload', function() {
        sessionStorage.setItem('lp_music_track', String(currentTrack));
        sessionStorage.setItem('lp_music_time', String(audio.currentTime));
        sessionStorage.setItem('lp_music_playing', String(isPlaying));
      });

      updateTrackDisplay();
    })();
  </script>
</body>
</html>

<style is:global>
  @import '@fontsource/bebas-neue/400.css';
  @import '@fontsource/cormorant-garamond/400.css';
  @import '@fontsource/cormorant-garamond/400-italic.css';
  @import '@fontsource/cormorant-garamond/600.css';
  @import '@fontsource/cormorant-garamond/700.css';
  @import '../styles/global.css';
</style>
